{% comment %}
  Section: Features Grid
  Heading + subheading centred above a row of icon-cards.
  Each card is a block with its own icon, title, description, and style settings.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --fg-section-pad-v:      {{ section.settings.section_pad_v }}px;
    --fg-section-pad-h:      {{ section.settings.section_pad_h }}px;
    --fg-section-bg:         {{ section.settings.section_bg }};
    --fg-max-width:          {{ section.settings.section_max_width }}px;

    --fg-title-color:        {{ section.settings.title_color }};
    --fg-title-size-d:       {{ section.settings.title_size_desktop }}px;
    --fg-title-size-m:       {{ section.settings.title_size_mobile }}px;
    --fg-title-weight:       {{ section.settings.title_weight }};

    --fg-desc-color:         {{ section.settings.desc_color }};
    --fg-desc-size-d:        {{ section.settings.desc_size_desktop }}px;
    --fg-desc-size-m:        {{ section.settings.desc_size_mobile }}px;
  }

  .fg-section {
    background: var(--fg-section-bg);
    padding: var(--fg-section-pad-v) var(--fg-section-pad-h);
  }

  .fg-inner {
    max-width: var(--fg-max-width);
    margin: 0 auto;
  }

  /* ── Header ── */
  .fg-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .fg-header__title {
    margin: 0 0 12px;
    font-size: var(--fg-title-size-d);
    font-weight: var(--fg-title-weight);
    color: var(--fg-title-color);
    line-height: 1.15;
    letter-spacing: 0.02em;
  }

  .fg-header__desc {
    margin: 0;
    font-size: var(--fg-desc-size-d);
    color: var(--fg-desc-color);
    line-height: 1.6;
  }

  /* ── Grid ── */
  .fg-grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  /* ── Card ── */
  .fg-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .fg-card__svg-wrap svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Icon wrapper ── */
  .fg-card__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }

  .fg-card__icon-wrap svg,
  .fg-card__icon-wrap img {
    display: block;
  }

  /* ── Card titles & descs are set per-block via inline style vars ── */
  .fg-card__title {
    margin: 0 0 12px;
    line-height: 1.25;
    letter-spacing: 0.04em;
  }

  .fg-card__desc {
    margin: 0;
    line-height: 1.6;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .fg-header__title { font-size: var(--fg-title-size-m); }
    .fg-header__desc  { font-size: var(--fg-desc-size-m); }

    .fg-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 480px) {
    .fg-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="fg-section">
  <div class="fg-inner">

    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="fg-header">
        {%- if section.settings.title != blank -%}
          <h2 class="fg-header__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="fg-header__desc">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="fg-grid">
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}
          <div
            class="fg-card"
            style="
              background: {{ b.card_bg }};
              padding: {{ b.card_pad_v }}px {{ b.card_pad_h }}px;
              border-radius: {{ b.card_radius }}px;
            "
            {{ block.shopify_attributes }}
          >

            {%- comment -%} Icon {%- endcomment -%}
            {%- if b.icon_svg != blank or b.icon_image != blank -%}
              <div
                class="fg-card__icon-wrap"
                style="
                  background: {{ b.icon_bg }};
                  border-radius: {{ b.icon_radius }}px;
                  width: {{ b.icon_circle_size }}px;
                  height: {{ b.icon_circle_size }}px;
                "
              >
                {%- if b.icon_image != blank -%}
                  {%- assign icon_style = 'width:' | append: b.icon_size | append: 'px;height:' | append: b.icon_size | append: 'px;object-fit:contain;' -%}
                  {{
                    b.icon_image
                    | image_url: width: 120
                    | image_tag:
                      width: b.icon_size,
                      height: b.icon_size,
                      style: icon_style
                  }}
                {%- elsif b.icon_svg != blank -%}
                  <span class="fg-card__svg-wrap" style="width:{{ b.icon_size }}px;height:{{ b.icon_size }}px;display:inline-flex;align-items:center;justify-content:center;">
                    {{ b.icon_svg }}
                  </span>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- comment -%} Card title {%- endcomment -%}
            {%- if b.card_title != blank -%}
              <p
                class="fg-card__title"
                style="
                  color: {{ b.card_title_color }};
                  font-size: {{ b.card_title_size_desktop }}px;
                  font-weight: {{ b.card_title_weight }};
                "
              >
                {{ b.card_title | escape }}
              </p>
            {%- endif -%}

            {%- comment -%} Card description {%- endcomment -%}
            {%- if b.card_desc != blank -%}
              <p
                class="fg-card__desc"
                style="
                  color: {{ b.card_desc_color }};
                  font-size: {{ b.card_desc_size_desktop }}px;
                "
              >
                {{ b.card_desc | escape }}
              </p>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{%- comment -%} Per-card mobile font sizes injected via a style tag {%- endcomment -%}
<style>
  @media screen and (max-width: 768px) {
    {%- for block in section.blocks -%}
      #shopify-section-{{ section.id }} .fg-grid > *:nth-child({{ forloop.index }}) .fg-card__title {
        font-size: {{ block.settings.card_title_size_mobile }}px;
      }
      #shopify-section-{{ section.id }} .fg-grid > *:nth-child({{ forloop.index }}) .fg-card__desc {
        font-size: {{ block.settings.card_desc_size_mobile }}px;
      }
    {%- endfor -%}
  }
</style>

