{% style %}
  .mission-hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      to right,
      {{ section.settings.bg_gradient_left }},
      {{ section.settings.bg_gradient_right }}
    );
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
  }

  .mission-hero__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .mission-hero__wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
    flex-wrap: wrap;
  }

  .mission-hero__content {
    flex: 1 1 500px;
  }

  .mission-hero__subtitle {
    position: relative;
    display: inline-block;
    margin: 0 0 35px;
    color: {{ section.settings.subtitle_color }};
    font-size: {{ section.settings.subtitle_size_mobile }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    line-height: 1.2;
    text-transform: uppercase;
  }

  .mission-hero__subtitle::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -14px;
    width: {{ section.settings.subtitle_border_width }}px;
    height: {{ section.settings.subtitle_border_height }}px;
    background: {{ section.settings.subtitle_border_color }};
    border-radius: 50px;
  }

  .mission-hero__title {
    margin: 0 0 24px;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.2;
    max-width: {{ section.settings.title_max_width }}px;
  }

  .mission-hero__description {
    margin-bottom: 35px;
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size_mobile }}px;
    font-weight: {{ section.settings.description_weight }};
    line-height: 1.7;
    max-width: {{ section.settings.description_max_width }}px;
  }

  .mission-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    padding: 8px 18px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ section.settings.button_radius }}px;
    transition: all 0.3s ease;
  }

  .mission-hero__button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .mission-hero__image-wrapper {
    flex: 1 1 550px;
    position: relative;
  }

  .mission-hero__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: {{ section.settings.image_radius }}px;
  }

  .mission-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: inherit;
  }

  @media screen and (min-width: 768px) {

    .mission-hero {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      padding-left: 40px;
      padding-right: 40px;
    }

    .mission-hero__subtitle {
      font-size: {{ section.settings.subtitle_size_desktop }}px;
    }

    .mission-hero__title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }

    .mission-hero__description {
      font-size: {{ section.settings.description_size_desktop }}px;
    }

    .mission-hero__image-wrapper {
      max-width: {{ section.settings.image_width_desktop }}px;
      height: {{ section.settings.image_height_desktop }}px;
    }
  }

  @media screen and (max-width: 767px) {

    .mission-hero__wrapper {
      gap: 40px;
    }

    .mission-hero__content {
      order: 2;
    }

    .mission-hero__image-wrapper {
      order: 1;
      width: 100%;
      max-width: {{ section.settings.image_width_mobile }}px;
      height: {{ section.settings.image_height_mobile }}px;
      margin: 0 auto;
    }

    .mission-hero__button {
      width: 100%;
    }
  }
{% endstyle %}

<section class="mission-hero">
  <div class="mission-hero__container">

    <div class="mission-hero__wrapper">

      <!-- Content -->
      <div class="mission-hero__content">

        {% if section.settings.subtitle != blank %}
          <div class="mission-hero__subtitle">
            {{ section.settings.subtitle }}
          </div>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="mission-hero__title">
            {{ section.settings.title }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="mission-hero__description">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.settings.button_text != blank %}
          <a
            href="{{ section.settings.button_link }}"
            class="mission-hero__button"
          >
            {{ section.settings.button_text }}
          </a>
        {% endif %}

      </div>

      <!-- Image -->
      <div class="mission-hero__image-wrapper">

        {% if section.settings.hero_image != blank %}
          <div class="mission-hero__image">
            {{
              section.settings.hero_image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                alt: section.settings.title
            }}
          </div>
        {% endif %}

      </div>

    </div>

  </div>
</section>

