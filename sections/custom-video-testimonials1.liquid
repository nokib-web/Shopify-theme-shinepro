    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "select",
      "id": "slides_desktop",
      "label": "Slides Visible (Desktop ≥1024px)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
