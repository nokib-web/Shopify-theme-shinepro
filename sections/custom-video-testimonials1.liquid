        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Block Style"
    },
    {
      "type": "range",
      "id": "block_radius",
      "label": "Block Border Radius",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "block_gap",
      "label": "Gap Between Blocks",
      "min": 8, "max": 48, "step": 4, "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "block_inner_gap",
      "label": "Inner Gap (Video ↔ Content)",
      "min": 0, "max": 32, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Star / Rating Icon"
    },
    {
      "type": "select",
      "id": "star_icon",
      "label": "Icon Shape",
      "options": [
        { "value": "star",    "label": "⭐ Star" },
        { "value": "heart",   "label": "❤️ Heart" },
        { "value": "circle",  "label": "⬤ Circle" },
        { "value": "diamond", "label": "◆ Diamond" }
      ],
      "default": "star"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Icon Size",
      "min": 10, "max": 36, "step": 2, "unit": "px",
      "default": 18
