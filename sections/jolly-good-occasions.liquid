{%- style -%}
  :root {
    --jg-occ-bg-{{ section.id }}: {{ section.settings.background_color }};
    
    /* Spacing */
    --jg-occ-pad-top-{{ section.id }}: {{ section.settings.pad_top }}px;
    --jg-occ-pad-bottom-{{ section.id }}: {{ section.settings.pad_bottom }}px;
    --jg-occ-mar-top-{{ section.id }}: {{ section.settings.mar_top }}px;
    --jg-occ-mar-bottom-{{ section.id }}: {{ section.settings.mar_bottom }}px;
    
    --jg-occ-pad-top-mob-{{ section.id }}: {{ section.settings.pad_top_mobile }}px;
    --jg-occ-pad-bottom-mob-{{ section.id }}: {{ section.settings.pad_bottom_mobile }}px;
    --jg-occ-mar-top-mob-{{ section.id }}: {{ section.settings.mar_top_mobile }}px;
    --jg-occ-mar-bottom-mob-{{ section.id }}: {{ section.settings.mar_bottom_mobile }}px;
  }
  
  .jg-occasions-{{ section.id }} {
    background-color: var(--jg-occ-bg-{{ section.id }});
    padding-top: var(--jg-occ-pad-top-{{ section.id }});
    padding-bottom: var(--jg-occ-pad-bottom-{{ section.id }});
    padding-left: 30px;
    padding-right: 30px;
    margin-top: var(--jg-occ-mar-top-{{ section.id }});
    margin-bottom: var(--jg-occ-mar-bottom-{{ section.id }});
    font-family: var(--jg-font-sans);
  }
  .jg-occasions__header {
    text-align: center;
    margin-bottom: 45px;
  }
  .jg-occasions__title {
    font-family: var(--jg-font-serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--jg-color-blue);
    margin: 0;
  }
  
  /* Grid Layout */
  .jg-occasions__grid {
    max-width: {% if section.settings.width_mode == 'boxed' %}1200px{% else %}100%{% endif %};
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 7 }}, 1fr);
    gap: 16px;
  }
  
  /* Occasion Card */
  .jg-occasions__card {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #f1ece1;
    overflow: visible;
    text-align: center;
    padding-bottom: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 4px 12px rgba(139, 122, 98, 0.03);
    position: relative;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .jg-occasions__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 25px rgba(139, 122, 98, 0.08);
  }
  
  /* Image wrapper with rounded top corners */
  .jg-occasions__img-wrapper {
    width: 100%;
    height: 110px;
    overflow: hidden;
    border-top-left-radius: 15px;
    border-top-right-radius: 15px;
    position: relative;
  }
  .jg-occasions__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .jg-occasions__card:hover .jg-occasions__img {
    transform: scale(1.08);
  }
  
  /* Overlapping circular badge icon */
  .jg-occasions__badge {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--jg-color-blue);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: -22px; /* Overlaps bottom of image */
    margin-bottom: 15px;
    border: 3px solid #ffffff;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    z-index: 2;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .jg-occasions__card:hover .jg-occasions__badge {
    background-color: var(--jg-color-gold);
    transform: scale(1.05);
  }
  .jg-occasions__badge svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  
  .jg-occasions__card-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--jg-color-blue);
    margin: 0 0 10px 0;
    padding: 0 10px;
  }
  
  .jg-occasions__link {
    font-size: 11px;
    font-weight: 700;
    color: var(--jg-color-gold);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s ease;
  }
  .jg-occasions__card:hover .jg-occasions__link {
    color: var(--jg-color-gold-hover);
    text-decoration: underline;
  }
  
  @media (max-width: 1200px) {
    .jg-occasions__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 15px;
    }
  }
  @media (max-width: 768px) {
    .jg-occasions-{{ section.id }} {
      padding-top: var(--jg-occ-pad-top-mob-{{ section.id }});
      padding-bottom: var(--jg-occ-pad-bottom-mob-{{ section.id }});
      margin-top: var(--jg-occ-mar-top-mob-{{ section.id }});
      margin-bottom: var(--jg-occ-mar-bottom-mob-{{ section.id }});
    }
    .jg-occasions__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .jg-occasions {
      padding: 40px 20px;
    }
  }
  @media (max-width: 480px) {
    .jg-occasions__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .jg-occasions__img-wrapper {
      height: 90px;
    }
    .jg-occasions__badge {
      width: 36px;
      height: 36px;
      margin-top: -18px;
      border-width: 2px;
    }
    .jg-occasions__badge svg {
      width: 14px;
      height: 14px;
    }
    .jg-occasions__card-title {
      font-size: 11px;
      margin-bottom: 6px;
    }
    .jg-occasions__link {
      font-size: 9px;
    }
  }

  {{ section.settings.custom_css }}
{%- endstyle -%}

<section 
  id="{{ section.settings.custom_id | default: section.id }}" 
  class="jg-occasions-{{ section.id }} {{ section.settings.custom_class }}"
  style="{{ section.settings.custom_style }}"
>
  <div class="jg-occasions__header">
    <h2 class="jg-occasions__title">{{ section.settings.title }}</h2>
  </div>

  <div class="jg-occasions__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="jg-occasions__card" {{ block.shopify_attributes }}>
        <div class="jg-occasions__img-wrapper">
          {%- if block.settings.image != blank -%}
            <img class="jg-occasions__img" src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" width="200" height="150" loading="lazy">
          {%- else -%}
            <!-- Fallbacks to static placeholder assets -->
            {%- case forloop.index -%}
              {%- when 1 -%}
                <img class="jg-occasions__img" src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=400&h=300&fit=crop" alt="College Students" width="200" height="150" loading="lazy">
              {%- when 2 -%}
                <img class="jg-occasions__img" src="https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=400&h=300&fit=crop" alt="Birthdays" width="200" height="150" loading="lazy">
              {%- when 3 -%}
                <img class="jg-occasions__img" src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=400&h=300&fit=crop" alt="Corporate" width="200" height="150" loading="lazy">
              {%- when 4 -%}
                <img class="jg-occasions__img" src="https://images.unsplash.com/photo-1513151233558-d860c5398176?w=400&h=300&fit=crop" alt="Care Packages" width="200" height="150" loading="lazy">
              {%- when 5 -%}
                <img class="jg-occasions__img" src="https://images.unsplash.com/photo-1576765608535-5f04d1e3f289?w=400&h=300&fit=crop" alt="Get Well Soon" width="200" height="150" loading="lazy">
              {%- when 6 -%}
                <img class="jg-occasions__img" src="https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?w=400&h=300&fit=crop" alt="Thank You" width="200" height="150" loading="lazy">
              {%- when 7 -%}
                <img class="jg-occasions__img" src="https://images.unsplash.com/photo-1544816155-12df9643f363?w=400&h=300&fit=crop" alt="Holidays" width="200" height="150" loading="lazy">
            {%- endcase -%}
          {%- endif -%}
        </div>
        
        <div class="jg-occasions__badge">
          {%- case block.settings.icon -%}
            {%- when 'cap' -%}
              <svg viewBox="0 0 24 24">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
              </svg>
            {%- when 'cake' -%}
              <svg viewBox="0 0 24 24">
                <path d="M20 21v-8H4v8zM18 13V9H6v4zM12 5V2M9 5V3M15 5V3"/>
              </svg>
            {%- when 'briefcase' -%}
              <svg viewBox="0 0 24 24">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
              </svg>
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            {%- when 'pulse' -%}
              <svg viewBox="0 0 24 24">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            {%- when 'gift' -%}
              <svg viewBox="0 0 24 24">
                <rect x="3" y="8" width="18" height="13" rx="2" ry="2"/>
                <path d="M12 21V8M7.5 8H12M16.5 8H12M12 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 1 0 0 5z"/>
              </svg>
            {%- when 'tree' -%}
              <svg viewBox="0 0 24 24">
                <polygon points="12 2 2 17 22 17"/>
                <rect x="10" y="17" width="4" height="5"/>
              </svg>
          {%- endcase -%}
        </div>
        
        <h3 class="jg-occasions__card-title">{{ block.settings.title }}</h3>
        <span class="jg-occasions__link">Shop Now &rarr;</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Jolly Good Occasions",
  "settings": [
    {
      "type": "header",
      "content": "Layout Controls"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "Width Mode",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "boxed", "label": "Boxed (1200px)" }
      ],
      "default": "boxed"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop By Occasion"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#fdfbf7"
    },
    {
      "type": "header",
      "content": "Spacing Sliders"
    },
    {
      "type": "range",
      "id": "pad_top",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "pad_bottom",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "mar_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "pad_bottom_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "mar_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Advanced Settings"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS overrides"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom HTML Classes"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom HTML id"
    },
    {
      "type": "text",
      "id": "custom_style",
      "label": "Custom Inline Styles"
    }
  ],
  "blocks": [
    {
      "type": "occasion",
      "name": "Occasion Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon Badge",
          "options": [
            { "value": "cap", "label": "Cap (College)" },
            { "value": "cake", "label": "Cake (Birthday)" },
            { "value": "briefcase", "label": "Briefcase (Corporate)" },
            { "value": "heart", "label": "Heart (Care Package)" },
            { "value": "pulse", "label": "Pulse (Get Well)" },
            { "value": "gift", "label": "Gift (Thank You)" },
            { "value": "tree", "label": "Tree (Holidays)" }
          ],
          "default": "gift"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jolly Good Occasions Grid"
    }
  ]
}
{% endschema %}
