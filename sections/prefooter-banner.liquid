    },
    {
      "type": "color",
      "id": "email_btn_bg",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "email_btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
