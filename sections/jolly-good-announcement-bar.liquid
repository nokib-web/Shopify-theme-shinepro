{%- style -%}
  :root {
    --jg-ann-bg-{{ section.id }}: {{ section.settings.background_color }};
    --jg-ann-bg-grad-{{ section.id }}: {{ section.settings.background_gradient }};
    --jg-ann-color-{{ section.id }}: {{ section.settings.text_color }};
    --jg-ann-icon-color-{{ section.id }}: {{ section.settings.icon_color }};
    --jg-ann-font-size-{{ section.id }}: {{ section.settings.font_size }}px;
    --jg-ann-spacing-{{ section.id }}: {{ section.settings.letter_spacing }}px;
    --jg-ann-weight-{{ section.id }}: {{ section.settings.font_weight }};
    
    /* Spacing */
    --jg-ann-pad-top-{{ section.id }}: {{ section.settings.pad_top }}px;
    --jg-ann-pad-bottom-{{ section.id }}: {{ section.settings.pad_bottom }}px;
    --jg-ann-pad-top-mob-{{ section.id }}: {{ section.settings.pad_top_mobile }}px;
    --jg-ann-pad-bottom-mob-{{ section.id }}: {{ section.settings.pad_bottom_mobile }}px;
  }
  
  .jg-announcement-bar-{{ section.id }} {
    background-color: var(--jg-ann-bg-{{ section.id }});
    {%- if section.settings.background_gradient != blank -%}
      background: var(--jg-ann-bg-grad-{{ section.id }});
    {%- endif -%}
    color: var(--jg-ann-color-{{ section.id }});
    padding-top: var(--jg-ann-pad-top-{{ section.id }});
    padding-bottom: var(--jg-ann-pad-bottom-{{ section.id }});
    padding-left: 20px;
    padding-right: 20px;
    font-family: var(--jg-font-sans);
    font-size: var(--jg-ann-font-size-{{ section.id }});
    font-weight: var(--jg-ann-weight-{{ section.id }});
    letter-spacing: var(--jg-ann-spacing-{{ section.id }});
    text-transform: uppercase;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    z-index: {{ section.settings.z_index }};
    position: relative;
    box-shadow: {% if section.settings.enable_shadow %}0 4px 10px rgba(0,0,0,0.05){% else %}none{% endif %};
  }
  .jg-announcement-bar__container {
    max-width: {% if section.settings.width_mode == 'boxed' %}1200px{% else %}100%{% endif %};
    margin: 0 auto;
    display: flex;
    justify-content: space-around;
    align-items: center;
    flex-wrap: wrap;
    gap: 15px;
  }
  .jg-announcement-bar__item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: inherit;
    text-decoration: none;
  }
  a.jg-announcement-bar__item:hover {
    opacity: 0.85;
  }
  .jg-announcement-bar__icon {
    width: 16px;
    height: 16px;
    fill: var(--jg-ann-icon-color-{{ section.id }});
    flex-shrink: 0;
  }
  .jg-announcement-bar__separator {
    color: rgba(255, 255, 255, 0.2);
    font-weight: 300;
  }
  @media (max-width: 768px) {
    .jg-announcement-bar-{{ section.id }} {
      padding-top: var(--jg-ann-pad-top-mob-{{ section.id }});
      padding-bottom: var(--jg-ann-pad-bottom-mob-{{ section.id }});
    }
    .jg-announcement-bar__container {
      justify-content: center;
      gap: 10px;
    }
    .jg-announcement-bar__separator {
      display: none;
    }
    .jg-announcement-bar__item {
      font-size: calc(var(--jg-ann-font-size-{{ section.id }}) - 1px);
    }
  }

  {{ section.settings.custom_css }}
{%- endstyle -%}

<div 
  id="{{ section.settings.custom_id | default: section.id }}" 
  class="jg-announcement-bar-{{ section.id }} {{ section.settings.custom_class }}"
  style="{{ section.settings.custom_style }}"
>
  <div class="jg-announcement-bar__container">
    {%- for block in section.blocks -%}
      {%- if forloop.first == false -%}
        <span class="jg-announcement-bar__separator" {{ block.shopify_attributes }}>|</span>
      {%- endif -%}
      
      {%- if block.settings.link != blank -%}
        <a href="{{ block.settings.link }}" class="jg-announcement-bar__item">
      {%- else -%}
        <div class="jg-announcement-bar__item">
      {%- endif -%}

        {%- case block.settings.icon -%}
          {%- when 'truck' -%}
            <svg class="jg-announcement-bar__icon" viewBox="0 0 24 24">
              <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm12.5-1.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-6H17V9h3v2z"/>
            </svg>
          {%- when 'box' -%}
            <svg class="jg-announcement-bar__icon" viewBox="0 0 24 24">
              <path d="M22 13.52V19c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2v-5.48c-.56-.37-.93-.98-.93-1.68V9c0-1.1.9-2 2-2h18c1.1 0 2 .9 2 2v2.84c0 .7-.37 1.31-.93 1.68zM4 9v2.84h16V9H4zm16 4.52H4V19h16v-5.48zM10 15h4v2h-4z"/>
            </svg>
          {%- when 'heart' -%}
            <svg class="jg-announcement-bar__icon" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          {%- when 'gift' -%}
            <svg class="jg-announcement-bar__icon" viewBox="0 0 24 24">
              <path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h16v6z"/>
            </svg>
        {%- endcase -%}
        
        <span>{{ block.settings.text }}</span>

      {%- if block.settings.link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Jolly Good Announcement",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Layout Controls"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "Width Mode",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "boxed", "label": "Boxed (1200px)" }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "Background Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#0b233a"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background Gradient"
    },
    {
      "type": "header",
      "content": "Typography Settings"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#fcf8f2"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#c59235"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 11
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 1
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "400 - Normal" },
        { "value": "600", "label": "600 - Semi-Bold" },
        { "value": "700", "label": "700 - Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "range",
      "id": "pad_top",
      "min": 2,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 10
    },
    {
      "type": "range",
      "id": "pad_bottom",
      "min": 2,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 10
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "min": 2,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 8
    },
    {
      "type": "range",
      "id": "pad_bottom_mobile",
      "min": 2,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 8
    },
    {
      "type": "header",
      "content": "Borders & Shadows"
    },
    {
      "type": "checkbox",
      "id": "enable_shadow",
      "label": "Enable Shadow",
      "default": false
    },
    {
      "type": "header",
      "content": "Advanced Settings"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS overrides"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom HTML Classes"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom HTML id"
    },
    {
      "type": "text",
      "id": "custom_style",
      "label": "Custom Inline Styles"
    },
    {
      "type": "range",
      "id": "z_index",
      "min": 1,
      "max": 50,
      "step": 1,
      "label": "Z-Index",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Announcement message"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "box", "label": "Box (Shipments)" },
            { "value": "heart", "label": "Heart (Handmade)" },
            { "value": "gift", "label": "Gift (Curated)" }
          ],
          "default": "truck"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jolly Good Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free Shipping on all orders",
            "icon": "truck"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Shipments go out daily",
            "icon": "box"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Handmade in the USA",
            "icon": "heart"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Curated gifts for every occasion",
            "icon": "gift"
          }
        }
      ]
    }
  ]
}
{% endschema %}
