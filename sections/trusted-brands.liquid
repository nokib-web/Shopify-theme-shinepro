{% comment %}
  ============================================================
  TRUSTED BY THOUSANDS — Logo Bar Section
  Shopify Liquid Section with full desktop & mobile customization
  ============================================================
{% endcomment %}


<section
  class="trusted-brands"
  id="trusted-brands-{{ section.id }}"
  style="
    --section-bg: {{ section.settings.background_color }};
    --heading-color: {{ section.settings.heading_color }};
    --subtext-color: {{ section.settings.subtext_color }};
    --logo-color-filter: {{ section.settings.logo_filter }};
    --logo-hover-filter: {{ section.settings.logo_hover_filter }};
    --section-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --section-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --section-margin-top: {{ section.settings.margin_top }}px;
    --section-margin-bottom: {{ section.settings.margin_bottom }}px;
    --section-max-width: {{ section.settings.section_max_width }}px;
    --logo-gap-desktop: {{ section.settings.logo_gap_desktop }}px;
    --logo-gap-mobile: {{ section.settings.logo_gap_mobile }}px;
    --logo-height-desktop: {{ section.settings.logo_height_desktop }}px;
    --logo-height-mobile: {{ section.settings.logo_height_mobile }}px;
    --divider-color: {{ section.settings.divider_color }};
    --heading-font-size-desktop: {{ section.settings.heading_font_size_desktop }}px;
    --heading-font-size-mobile: {{ section.settings.heading_font_size_mobile }}px;
    --subtext-font-size-desktop: {{ section.settings.subtext_font_size_desktop }}px;
    --subtext-font-size-mobile: {{ section.settings.subtext_font_size_mobile }}px;
    --heading-letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    --heading-font-weight: {{ section.settings.heading_font_weight }};
    --logos-per-row-desktop: {{ section.settings.logos_per_row_desktop }};
    --logos-per-row-mobile: {{ section.settings.logos_per_row_mobile }};
    --logo-opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
    --logo-hover-opacity: {{ section.settings.logo_hover_opacity | divided_by: 100.0 }};
    --logo-transition-speed: {{ section.settings.logo_transition_speed }}ms;
    --section-border-top: {{ section.settings.border_top_width }}px solid {{ section.settings.border_color }};
    --section-border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_color }};
  "
>
  <div class="trusted-brands__inner">

    {% if section.settings.show_heading or section.settings.show_subtext %}
      <div class="trusted-brands__header" style="
        text-align: {{ section.settings.text_alignment }};
        margin-bottom: {{ section.settings.header_margin_bottom }}px;
      ">
        {% if section.settings.show_heading and section.settings.heading != blank %}
          <{{ section.settings.heading_tag }} class="trusted-brands__heading" style="
            font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
            font-style: {{ section.settings.heading_font.style }};
          ">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {% endif %}

        {% if section.settings.show_subtext and section.settings.subtext != blank %}
          <p class="trusted-brands__subtext" style="
            font-family: {{ section.settings.subtext_font.family }}, {{ section.settings.subtext_font.fallback_families }};
            font-style: {{ section.settings.subtext_font.style }};
          ">
            {{ section.settings.subtext }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.show_divider %}
      <div class="trusted-brands__divider"></div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="trusted-brands__logos {% if section.settings.enable_scroll %}trusted-brands__logos--scroll{% endif %}">
        {% if section.settings.enable_scroll %}
          <div class="trusted-brands__track">
        {% endif %}

        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <div class="trusted-brands__logo-item" {{ block.shopify_attributes }}>
              {% if block.settings.logo_link != blank %}
                <a href="{{ block.settings.logo_link }}" 
                   {% if block.settings.link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                   class="trusted-brands__logo-link"
                   aria-label="{{ block.settings.logo_alt | default: block.settings.brand_name }}">
              {% endif %}

              {% if block.settings.logo_image != blank %}
                <img
                  src="{{ block.settings.logo_image | image_url: width: 300 }}"
                  srcset="{{ block.settings.logo_image | image_url: width: 150 }} 150w,
                          {{ block.settings.logo_image | image_url: width: 300 }} 300w,
                          {{ block.settings.logo_image | image_url: width: 600 }} 600w"
                  sizes="(max-width: 749px) {{ section.settings.logo_height_mobile }}px, {{ section.settings.logo_height_desktop }}px"
                  alt="{{ block.settings.logo_alt | default: block.settings.brand_name | escape }}"
                  class="trusted-brands__logo-img"
                  loading="lazy"
                  width="{{ block.settings.logo_image.width }}"
                  height="{{ block.settings.logo_image.height }}"
                  style="
                    {% if block.settings.logo_width_override > 0 %}
                      width: {{ block.settings.logo_width_override }}px;
                    {% endif %}
                  "
                >
              {% elsif block.settings.brand_name != blank %}
                <span class="trusted-brands__logo-text" style="
                  font-size: {{ section.settings.logo_height_desktop | times: 0.5 }}px;
                  color: {{ section.settings.heading_color }};
                ">{{ block.settings.brand_name }}</span>
              {% endif %}

              {% if block.settings.logo_link != blank %}</a>{% endif %}
            </div>
          {% endif %}
        {% endfor %}

        {% if section.settings.enable_scroll %}
          {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
          {% for block in section.blocks %}
            {% if block.type == 'logo' %}
              <div class="trusted-brands__logo-item trusted-brands__logo-item--clone" aria-hidden="true">
                {% if block.settings.logo_image != blank %}
                  <img
                    src="{{ block.settings.logo_image | image_url: width: 300 }}"
                    alt=""
                    class="trusted-brands__logo-img"
                    loading="lazy"
                    width="{{ block.settings.logo_image.width }}"
                    height="{{ block.settings.logo_image.height }}"
                  >
                {% elsif block.settings.brand_name != blank %}
                  <span class="trusted-brands__logo-text">{{ block.settings.brand_name }}</span>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
          </div>{% comment %}close track{% endcomment %}
        {% endif %}

      </div>
    {% else %}
      {% if request.design_mode %}
        <p style="text-align:center; color: #999; padding: 20px;">Add logo blocks in the section editor →</p>
      {% endif %}
    {% endif %}

  </div>
</section>

<style>
  /* ===== BASE SECTION ===== */
  #trusted-brands-{{ section.id }} {
    background-color: var(--section-bg);
    margin-top: var(--section-margin-top);
    margin-bottom: var(--section-margin-bottom);
    padding-top: var(--section-padding-top-desktop);
    padding-bottom: var(--section-padding-bottom-desktop);
    border-top: var(--section-border-top);
    border-bottom: var(--section-border-bottom);
    overflow: hidden;
  }

  #trusted-brands-{{ section.id }} .trusted-brands__inner {
    max-width: var(--section-max-width);
    margin: 0 auto;
    padding-left: {{ section.settings.horizontal_padding }}px;
    padding-right: {{ section.settings.horizontal_padding }}px;
  }

  /* ===== HEADER ===== */
  #trusted-brands-{{ section.id }} .trusted-brands__heading {
    font-size: var(--heading-font-size-desktop);
    font-weight: var(--heading-font-weight);
    color: var(--heading-color);
    letter-spacing: var(--heading-letter-spacing);
    margin: 0 0 6px;
    line-height: 1.3;
    text-transform: {{ section.settings.heading_text_transform }};
  }

  #trusted-brands-{{ section.id }} .trusted-brands__subtext {
    font-size: var(--subtext-font-size-desktop);
    color: var(--subtext-color);
    margin: 0;
    line-height: 1.5;
  }

  /* ===== DIVIDER ===== */
  #trusted-brands-{{ section.id }} .trusted-brands__divider {
    height: {{ section.settings.divider_height }}px;
    background: var(--divider-color);
    margin: {{ section.settings.divider_margin }}px auto;
    width: {{ section.settings.divider_width }}%;
    border-radius: 99px;
  }

  /* ===== LOGOS GRID ===== */
  #trusted-brands-{{ section.id }} .trusted-brands__logos:not(.trusted-brands__logos--scroll) {
    display: grid;
    grid-template-columns: repeat(var(--logos-per-row-desktop), 1fr);
    gap: var(--logo-gap-desktop);
    align-items: center;
    justify-items: center;
  }

  /* ===== LOGO ITEM ===== */
  #trusted-brands-{{ section.id }} .trusted-brands__logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #trusted-brands-{{ section.id }} .trusted-brands__logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #trusted-brands-{{ section.id }} .trusted-brands__logo-img {
    height: var(--logo-height-desktop);
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: var(--logo-color-filter);
    opacity: var(--logo-opacity);
    transition: filter var(--logo-transition-speed) ease,
                opacity var(--logo-transition-speed) ease,
                transform var(--logo-transition-speed) ease;
    display: block;
  }

  {% if section.settings.enable_hover_effect %}
  #trusted-brands-{{ section.id }} .trusted-brands__logo-item:hover .trusted-brands__logo-img {
    filter: var(--logo-hover-filter);
    opacity: var(--logo-hover-opacity);
    transform: scale({{ section.settings.hover_scale | divided_by: 100.0 }});
  }
  {% endif %}

  /* ===== SCROLL / MARQUEE ===== */
  #trusted-brands-{{ section.id }} .trusted-brands__logos--scroll {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  #trusted-brands-{{ section.id }} .trusted-brands__track {
    display: flex;
    align-items: center;
    gap: var(--logo-gap-desktop);
    width: max-content;
    animation: trusted-scroll-{{ section.id }} {{ section.settings.scroll_speed }}s linear infinite;
    {% if section.settings.scroll_direction == 'right' %}
    animation-direction: reverse;
    {% endif %}
  }

  #trusted-brands-{{ section.id }} .trusted-brands__track:hover {
    {% if section.settings.pause_on_hover %}animation-play-state: paused;{% endif %}
  }

  @keyframes trusted-scroll-{{ section.id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 749px) {
    #trusted-brands-{{ section.id }} {
      padding-top: var(--section-padding-top-mobile);
      padding-bottom: var(--section-padding-bottom-mobile);
    }

    #trusted-brands-{{ section.id }} .trusted-brands__inner {
      padding-left: {{ section.settings.horizontal_padding_mobile }}px;
      padding-right: {{ section.settings.horizontal_padding_mobile }}px;
    }

    #trusted-brands-{{ section.id }} .trusted-brands__heading {
      font-size: var(--heading-font-size-mobile);
    }

    #trusted-brands-{{ section.id }} .trusted-brands__subtext {
      font-size: var(--subtext-font-size-mobile);
    }

    #trusted-brands-{{ section.id }} .trusted-brands__logos:not(.trusted-brands__logos--scroll) {
      grid-template-columns: repeat(var(--logos-per-row-mobile), 1fr);
      gap: var(--logo-gap-mobile);
    }

    #trusted-brands-{{ section.id }} .trusted-brands__logo-img {
      height: var(--logo-height-mobile);
    }

    #trusted-brands-{{ section.id }} .trusted-brands__track {
      gap: var(--logo-gap-mobile);
    }
  }
</style>

{% schema %}
{
  "name": "Trusted Brands Bar",
  "tag": "section",
  "class": "trusted-brands-section",
  "max_blocks": 20,
  "settings": [

    {
      "type": "header",
      "content": "🎨 Section Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Max section width (px)",
      "min": 600,
      "max": 2000,
      "step": 20,
      "default": 1200
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding — desktop (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "horizontal_padding_mobile",
      "label": "Horizontal padding — mobile (px)",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20
    },

    {
      "type": "header",
      "content": "📐 Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top — desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom — desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },

    {
      "type": "header",
      "content": "📱 Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom — mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 28
    },

    {
      "type": "header",
      "content": "↕️ Section Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0
    },

    {
      "type": "header",
      "content": "─── Borders"
    },
    {
      "type": "range",
      "id": "border_top_width",
      "label": "Border top width (px)",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "label": "Border bottom width (px)",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 0
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e8e8e8"
    },

    {
      "type": "header",
      "content": "✏️ Heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "TRUSTED BY THOUSANDS"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "p",  "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n7"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading font size — desktop (px)",
      "min": 10,
      "max": 60,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size — mobile (px)",
      "min": 10,
      "max": 40,
      "step": 1,
      "default": 13
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra Bold (800)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_text_transform",
      "label": "Heading text transform",
      "options": [
        { "value": "none",       "label": "None" },
        { "value": "uppercase",  "label": "Uppercase" },
        { "value": "lowercase",  "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Letter spacing (px)",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 1
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },

    {
      "type": "header",
      "content": "💬 Subtext"
    },
    {
      "type": "checkbox",
      "id": "show_subtext",
      "label": "Show subtext",
      "default": true
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join happy customers and top brands who love our store."
    },
    {
      "type": "font_picker",
      "id": "subtext_font",
      "label": "Subtext font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "subtext_font_size_desktop",
      "label": "Subtext font size — desktop (px)",
      "min": 10,
      "max": 28,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "subtext_font_size_mobile",
      "label": "Subtext font size — mobile (px)",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 12
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#777777"
    },

    {
      "type": "header",
      "content": "↔️ Text Alignment"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "label": "Space below header (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },

    {
      "type": "header",
      "content": "— Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": false
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Divider height (px)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Divider width (%)",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 80
    },
    {
      "type": "range",
      "id": "divider_margin",
      "label": "Divider vertical margin (px)",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16
    },

    {
      "type": "header",
      "content": "🖼️ Logo Grid — Desktop"
    },
    {
      "type": "range",
      "id": "logos_per_row_desktop",
      "label": "Logos per row — desktop",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "logo_height_desktop",
      "label": "Logo height — desktop (px)",
      "min": 16,
      "max": 120,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "logo_gap_desktop",
      "label": "Gap between logos — desktop (px)",
      "min": 8,
      "max": 100,
      "step": 4,
      "default": 48
    },

    {
      "type": "header",
      "content": "📱 Logo Grid — Mobile"
    },
    {
      "type": "range",
      "id": "logos_per_row_mobile",
      "label": "Logos per row — mobile",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Logo height — mobile (px)",
      "min": 14,
      "max": 80,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "logo_gap_mobile",
      "label": "Gap between logos — mobile (px)",
      "min": 8,
      "max": 60,
      "step": 4,
      "default": 24
    },

    {
      "type": "header",
      "content": "🎨 Logo Appearance"
    },
    {
      "type": "select",
      "id": "logo_filter",
      "label": "Logo color treatment",
      "options": [
        { "value": "none",              "label": "Original (no filter)" },
        { "value": "grayscale(100%)",   "label": "Grayscale" },
        { "value": "grayscale(100%) brightness(0)", "label": "Black silhouette" },
        { "value": "grayscale(100%) invert(1)", "label": "White silhouette" },
        { "value": "grayscale(100%) brightness(1.5)", "label": "Light grey" },
        { "value": "grayscale(100%) contrast(0.5)", "label": "Faded grey" }
      ],
      "default": "grayscale(100%)"
    },
    {
      "type": "select",
      "id": "logo_hover_filter",
      "label": "Logo hover treatment",
      "options": [
        { "value": "none",            "label": "Original (no filter)" },
        { "value": "grayscale(100%)", "label": "Grayscale" },
        { "value": "grayscale(0%)",   "label": "Color (remove filter)" },
        { "value": "grayscale(100%) brightness(0)", "label": "Black silhouette" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "Logo opacity (%)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "logo_hover_opacity",
