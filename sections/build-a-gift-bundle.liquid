    { "type": "range", "id": "body_size_mobile", "label": "Body size — Mobile", "min": 11, "max": 18, "step": 1, "default": 13, "unit": "px" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1a1a1a" },
