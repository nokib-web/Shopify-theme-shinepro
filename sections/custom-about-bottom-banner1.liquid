{% style %}
  .spread-joy-banner {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      to right,
      {{ section.settings.bg_gradient_left }},
      {{ section.settings.bg_gradient_right }}
    );

    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
  }

  .spread-joy-banner__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .spread-joy-banner__wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
  }

  /* LEFT IMAGE COLUMN */
  .spread-joy-banner__image-column {
    flex: 0 0 33.333%;
    max-width: 33.333%;

    display: flex;
    justify-content: flex-end;
  }

  .spread-joy-banner__image-wrapper {
    width: 100%;
    text-align: right;
  }

  .spread-joy-banner__image-wrapper img {
    width: {{ section.settings.image_width_desktop }}px;
    max-width: 100%;
    height: auto;
    display: inline-block;
    object-fit: cover;
    border-radius: {{ section.settings.image_radius }}px;
    vertical-align: middle;
  }

  /* RIGHT CONTENT COLUMN */
  .spread-joy-banner__content-column {
    flex: 0 0 calc(66.666% - 60px);
    max-width: calc(66.666% - 60px);
  }

  .spread-joy-banner__content {
    text-align: left;
  }

  .spread-joy-banner__title {
    margin: 0 0 20px;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.2;
    max-width: {{ section.settings.title_max_width }}px;
  }

  .spread-joy-banner__description {
    margin-bottom: 35px;
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size_mobile }}px;
    font-weight: {{ section.settings.description_weight }};
    line-height: 1.7;
    max-width: {{ section.settings.description_max_width }}px;
  }

  /* BUTTON */
  .spread-joy-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.3s ease;

    background: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};

    padding-top: {{ section.settings.button_padding_vertical }}px;
    padding-bottom: {{ section.settings.button_padding_vertical }}px;
    padding-left: {{ section.settings.button_padding_horizontal }}px;
    padding-right: {{ section.settings.button_padding_horizontal }}px;

    border-radius: {{ section.settings.button_radius }}px;

    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
  }

  .spread-joy-banner__button:hover {
    background: {{ section.settings.button_hover_bg }};
    color: {{ section.settings.button_hover_color }};
  }

  /* DESKTOP */
  @media screen and (min-width: 768px) {

    .spread-joy-banner {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      padding-left: 40px;
      padding-right: 40px;
    }

    .spread-joy-banner__title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }

    .spread-joy-banner__description {
      font-size: {{ section.settings.description_size_desktop }}px;
    }
  }

  /* MOBILE */
  @media screen and (max-width: 767px) {

    .spread-joy-banner__wrapper {
      flex-direction: column;
      gap: 40px;
    }

    .spread-joy-banner__image-column,
    .spread-joy-banner__content-column {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .spread-joy-banner__image-column {
      justify-content: center;
    }

    .spread-joy-banner__image-wrapper {
      text-align: center;
    }

    .spread-joy-banner__image-wrapper img {
      width: {{ section.settings.image_width_mobile }}px;
    }

    .spread-joy-banner__title {
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    .spread-joy-banner__description {
      font-size: {{ section.settings.description_size_mobile }}px;
    }

    .spread-joy-banner__button {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<section class="spread-joy-banner">
  <div class="spread-joy-banner__container">

    <div class="spread-joy-banner__wrapper">

      <!-- LEFT IMAGE -->
      <div class="spread-joy-banner__image-column">

        {% if section.settings.left_image != blank %}
          <div class="spread-joy-banner__image-wrapper">

            {{
              section.settings.left_image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                widths: '300,400,500,600,700,800,1000,1200',
                sizes: '(min-width: 768px) 33vw, 100vw',
                alt: section.settings.title
            }}

          </div>
        {% endif %}

      </div>

      <!-- RIGHT CONTENT -->
      <div class="spread-joy-banner__content-column">

        <div class="spread-joy-banner__content">

          {% if section.settings.title != blank %}
            <h2 class="spread-joy-banner__title">
              {{ section.settings.title }}
            </h2>
          {% endif %}

          {% if section.settings.description != blank %}
            <div class="spread-joy-banner__description">
              {{ section.settings.description }}
            </div>
          {% endif %}

          {% if section.settings.button_text != blank %}
            <a
              href="{{ section.settings.button_link }}"
              class="spread-joy-banner__button"
            >
              {{ section.settings.button_text }}
            </a>
          {% endif %}

        </div>

      </div>

    </div>

  </div>
</section>

{% schema %}
