{% comment %}
  Section: Newsletter Signup
  Full-width coloured band with centred heading, badge, email form, and footnote.
  Connects to Shopify's built-in newsletter / customer mailing list.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --ns-pad-v:            {{ section.settings.section_pad_v }}px;
    --ns-pad-h:            {{ section.settings.section_pad_h }}px;
    --ns-bg:               {{ section.settings.section_bg }};
    --ns-max-width:        {{ section.settings.section_max_width }}px;

    --ns-title-color:      {{ section.settings.title_color }};
    --ns-title-d:          {{ section.settings.title_size_desktop }}px;
    --ns-title-m:          {{ section.settings.title_size_mobile }}px;
    --ns-title-weight:     {{ section.settings.title_weight }};

    --ns-desc-color:       {{ section.settings.desc_color }};
    --ns-desc-d:           {{ section.settings.desc_size_desktop }}px;
    --ns-desc-m:           {{ section.settings.desc_size_mobile }}px;

    --ns-badge-color:      {{ section.settings.badge_color }};
    --ns-badge-d:          {{ section.settings.badge_size_desktop }}px;
    --ns-badge-m:          {{ section.settings.badge_size_mobile }}px;
    --ns-badge-grad-from:  {{ section.settings.badge_grad_from }};
    --ns-badge-grad-to:    {{ section.settings.badge_grad_to }};

    --ns-input-radius:     {{ section.settings.input_radius }}px;
    --ns-input-pad-v:      {{ section.settings.input_pad_v }}px;
    --ns-input-pad-h:      {{ section.settings.input_pad_h }}px;

    --ns-btn-color:        {{ section.settings.btn_text_color }};
    --ns-btn-d:            {{ section.settings.btn_size_desktop }}px;
    --ns-btn-m:            {{ section.settings.btn_size_mobile }}px;
    --ns-btn-weight:       {{ section.settings.btn_weight }};
    --ns-btn-grad-from:    {{ section.settings.btn_grad_from }};
    --ns-btn-grad-to:      {{ section.settings.btn_grad_to }};
    --ns-btn-hover:        {{ section.settings.btn_hover_bg }};
    --ns-btn-radius:       {{ section.settings.btn_radius }}px;
    --ns-btn-pad-v:        {{ section.settings.btn_pad_v }}px;
    --ns-btn-pad-h:        {{ section.settings.btn_pad_h }}px;

    --ns-note-color:       {{ section.settings.note_color }};
    --ns-note-d:           {{ section.settings.note_size_desktop }}px;
    --ns-note-m:           {{ section.settings.note_size_mobile }}px;
  }

  .ns-section {
    background: var(--ns-bg);
    padding: var(--ns-pad-v) var(--ns-pad-h);
  }

  .ns-inner {
    max-width: var(--ns-max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* ── Title ── */
  .ns-title {
    margin: 0 0 16px;
    font-size: var(--ns-title-d);
    font-weight: var(--ns-title-weight);
    color: var(--ns-title-color);
    line-height: 1.15;
    letter-spacing: 0.02em;
  }

  /* ── Description ── */
  .ns-desc {
    margin: 0 0 28px;
    font-size: var(--ns-desc-d);
    color: var(--ns-desc-color);
    line-height: 1.6;
    max-width: 560px;
  }

  /* ── Badge ── */
  .ns-badge {
    display: inline-block;
    font-size: var(--ns-badge-d);
    color: var(--ns-badge-color);
    background: linear-gradient(to right, var(--ns-badge-grad-from), var(--ns-badge-grad-to));
    padding: 10px 24px;
    border-radius: 6px;
    margin-bottom: 28px;
    line-height: 1.3;
  }

  /* ── Form row ── */
  .ns-form {
    width: 100%;
    max-width: 560px;
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .ns-form__input {
    flex: 1;
    padding: var(--ns-input-pad-v) var(--ns-input-pad-h);
    border: none;
    border-radius: var(--ns-input-radius);
    font-size: 15px;
    color: #1a1a1a;
    background: #ffffff;
    outline: none;
    box-shadow: none;
    -webkit-appearance: none;
  }

  .ns-form__input::placeholder {
    color: #a0a0a0;
  }

  .ns-form__input:focus {
    box-shadow: 0 0 0 3px rgba(0,0,0,0.12);
  }

  .ns-form__btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--ns-btn-pad-v) var(--ns-btn-pad-h);
    background: linear-gradient(to right, var(--ns-btn-grad-from), var(--ns-btn-grad-to));
    color: var(--ns-btn-color);
    font-size: var(--ns-btn-d);
    font-weight: var(--ns-btn-weight);
    border-radius: var(--ns-btn-radius);
    border: 2px solid #FF7BA0;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.22s ease, opacity 0.22s ease;
    white-space: nowrap;
  }

  .ns-form__btn:hover {
    background: var(--ns-btn-hover);
  }

  /* ── Form note ── */
  .ns-note {
    margin: 0;
    font-size: var(--ns-note-d);
    color: var(--ns-note-color);
    line-height: 1.5;
  }

  /* ── Success / error messages ── */
  .ns-message {
    display: none;
    margin-top: 12px;
    font-size: 14px;
    font-weight: 600;
  }

  .ns-message--success { color: #1a6e2e; }
  .ns-message--error   { color: #b91c1c; }

  /* ── Mobile ── */
  @media screen and (max-width: 600px) {
    .ns-title       { font-size: var(--ns-title-m); }
    .ns-desc        { font-size: var(--ns-desc-m); }
    .ns-badge       { font-size: var(--ns-badge-m); }
    .ns-form__btn   { font-size: var(--ns-btn-m); }
    .ns-note        { font-size: var(--ns-note-m); }

    .ns-form {
      flex-direction: column;
      gap: 10px;
    }

    .ns-form__btn {
      width: 100%;
    }
  }
</style>

<section class="ns-section">
  <div class="ns-inner">

    {%- if section.settings.title != blank -%}
      <h2 class="ns-title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="ns-desc">{{ section.settings.description | escape }}</p>
    {%- endif -%}

    {%- if section.settings.badge_text != blank -%}
      <span class="ns-badge">{{ section.settings.badge_text | escape }}</span>
    {%- endif -%}

    {%- form 'customer', id: 'ns-form-{{ section.id }}', class: 'ns-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      <input
        class="ns-form__input"
        type="email"
        name="contact[email]"
        id="ns-email-{{ section.id }}"
        autocomplete="email"
        autocorrect="off"
        autocapitalize="off"
        placeholder="{{ section.settings.input_placeholder | escape }}"
        aria-label="{{ section.settings.input_placeholder | escape }}"
        required
      >

      <button type="submit" class="ns-form__btn">
        {{ section.settings.btn_label | escape }}
      </button>
    {%- endform -%}

    {%- if form.posted_successfully? -%}
      <p class="ns-message ns-message--success" style="display:block;">
        {{ section.settings.success_message | escape }}
      </p>
    {%- endif -%}

    {%- if section.settings.form_note != blank -%}
      <p class="ns-note">{{ section.settings.form_note | escape }}</p>
    {%- endif -%}

  </div>
</section>

