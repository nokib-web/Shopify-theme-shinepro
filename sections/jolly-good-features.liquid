{%- style -%}
  :root {
    --jg-feat-bg-{{ section.id }}: {{ section.settings.background_color }};
    
    /* Spacing */
    --jg-feat-pad-top-{{ section.id }}: {{ section.settings.pad_top }}px;
    --jg-feat-pad-bottom-{{ section.id }}: {{ section.settings.pad_bottom }}px;
    --jg-feat-mar-top-{{ section.id }}: {{ section.settings.mar_top }}px;
    --jg-feat-mar-bottom-{{ section.id }}: {{ section.settings.mar_bottom }}px;
    
    --jg-feat-pad-top-mob-{{ section.id }}: {{ section.settings.pad_top_mobile }}px;
    --jg-feat-pad-bottom-mob-{{ section.id }}: {{ section.settings.pad_bottom_mobile }}px;
    --jg-feat-mar-top-mob-{{ section.id }}: {{ section.settings.mar_top_mobile }}px;
    --jg-feat-mar-bottom-mob-{{ section.id }}: {{ section.settings.mar_bottom_mobile }}px;
  }
  
  .jg-features-{{ section.id }} {
    background-color: var(--jg-feat-bg-{{ section.id }});
    padding-top: var(--jg-feat-pad-top-{{ section.id }});
    padding-bottom: var(--jg-feat-pad-bottom-{{ section.id }});
    padding-left: 30px;
    padding-right: 30px;
    margin-top: var(--jg-feat-mar-top-{{ section.id }});
    margin-bottom: var(--jg-feat-mar-bottom-{{ section.id }});
    font-family: var(--jg-font-sans);
  }
  .jg-features__container {
    max-width: {% if section.settings.width_mode == 'boxed' %}1200px{% else %}100%{% endif %};
    margin: 0 auto;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(139, 122, 98, 0.06);
    border: 1px solid #f1ece1;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    padding: 30px;
    gap: 20px;
  }
  .jg-features__card {
    text-align: center;
    padding: 15px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }
  /* Vertical dividers for desktop */
  .jg-features__card:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -10px;
    top: 20%;
    bottom: 20%;
    width: 1px;
    background-color: #ede7db;
  }
  .jg-features__icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: #faf6f0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
    color: var(--jg-color-gold);
    transition: transform 0.3s ease;
  }
  .jg-features__card:hover .jg-features__icon-wrapper {
    transform: scale(1.1);
  }
  .jg-features__icon-wrapper svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .jg-features__title {
    font-family: var(--jg-font-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--jg-color-blue);
    margin: 0 0 8px 0;
  }
  .jg-features__text {
    font-size: 13px;
    line-height: 1.4;
    color: #666666;
    margin: 0;
    max-width: 200px;
  }
  
  @media (max-width: 991px) {
    .jg-features-{{ section.id }} {
      padding-top: var(--jg-feat-pad-top-mob-{{ section.id }});
      padding-bottom: var(--jg-feat-pad-bottom-mob-{{ section.id }});
      margin-top: var(--jg-feat-mar-top-mob-{{ section.id }});
      margin-bottom: var(--jg-feat-mar-bottom-mob-{{ section.id }});
    }
    .jg-features__container {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
    .jg-features__card::after {
      display: none;
    }
  }
  @media (max-width: 576px) {
    .jg-features__container {
      grid-template-columns: 1fr;
      padding: 20px;
    }
  }

  {{ section.settings.custom_css }}
{%- endstyle -%}

<section 
  id="{{ section.settings.custom_id | default: section.id }}" 
  class="jg-features-{{ section.id }} {{ section.settings.custom_class }}"
  style="{{ section.settings.custom_style }}"
>
  <div class="jg-features__container">
    {%- for block in section.blocks -%}
      <div class="jg-features__card" {{ block.shopify_attributes }}>
        <div class="jg-features__icon-wrapper">
          {%- case block.settings.icon -%}
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24">
                <rect x="1" y="3" width="15" height="13" rx="2" ry="2"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            {%- when 'box' -%}
              <svg viewBox="0 0 24 24">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                <line x1="12" y1="22.08" x2="12" y2="12"></line>
              </svg>
            {%- when 'gift' -%}
              <svg viewBox="0 0 24 24">
                <path d="M20 12v10H4V12"></path>
                <path d="M2 7h20v5H2z"></path>
                <path d="M12 22V7"></path>
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
              </svg>
          {%- endcase -%}
        </div>
        <h3 class="jg-features__title">{{ block.settings.title }}</h3>
        <p class="jg-features__text">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Jolly Good Features",
  "settings": [
    {
      "type": "header",
      "content": "Layout Controls"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "Width Mode",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "boxed", "label": "Boxed (1200px)" }
      ],
      "default": "boxed"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#fdfbf7"
    },
    {
      "type": "header",
      "content": "Spacing Sliders"
    },
    {
      "type": "range",
      "id": "pad_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "pad_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 50
    },
    {
      "type": "range",
      "id": "mar_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "pad_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "mar_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Advanced Settings"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS overrides"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom HTML Classes"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom HTML id"
    },
    {
      "type": "text",
      "id": "custom_style",
      "label": "Custom Inline Styles"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text Details",
          "default": "Feature description goes here."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "heart", "label": "Heart (Handmade)" },
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "box", "label": "Box (Treats)" },
            { "value": "gift", "label": "Gift (Ribbon)" }
          ],
          "default": "heart"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jolly Good Features Grid"
    }
  ]
}
{% endschema %}
