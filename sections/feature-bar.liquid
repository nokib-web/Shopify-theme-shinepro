{% comment %}
  Feature Bar Section
  Displays 2–6 icon + heading + text feature blocks in a horizontal row.
  Full desktop & mobile customization in Schema.
{% endcomment %}

{%- liquid
  assign bg_color       = section.settings.background_color
  assign section_height = section.settings.section_padding_vertical
  assign icon_bg        = section.settings.icon_bg_color
  assign icon_color     = section.settings.icon_color
  assign heading_color  = section.settings.heading_color
  assign text_color     = section.settings.text_color
  assign align          = section.settings.text_align
  assign max_width      = section.settings.max_width
  if section.settings.show_decorations
    assign deco_display = 'block'
  else
    assign deco_display = 'none'
  endif
  if section.settings.heading_font_family != blank and section.settings.heading_font_family != 'inherit'
    assign heading_ff = section.settings.heading_font_family
  else
    assign heading_ff = 'inherit'
  endif
  if section.settings.text_font_family != blank and section.settings.text_font_family != 'inherit'
    assign text_ff = section.settings.text_font_family
  else
    assign text_ff = 'inherit'
  endif
-%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ bg_color }};
  }

  .feature-bar--{{ section.id }} {
    max-width: {{ max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-top: {{ section_height }}px;
    padding-bottom: {{ section_height }}px;
    padding-left: {{ section.settings.section_padding_horizontal }}px;
    padding-right: {{ section.settings.section_padding_horizontal }}px;
    display: flex;
    flex-wrap: wrap;
    gap: {{ section.settings.gap }}px;
    justify-content: {{ section.settings.justify_content }};
    align-items: {{ section.settings.align_items }};
    position: relative;
  }

  /* Decorative hearts */
  .feature-bar--{{ section.id }}::before,
  .feature-bar--{{ section.id }}::after {
    content: '♥';
    position: absolute;
    color: {{ icon_color }};
    opacity: 0.35;
    font-size: 14px;
    pointer-events: none;
    display: {{ deco_display }};
  }
  .feature-bar--{{ section.id }}::before { top: 18px; left: 24px; }
  .feature-bar--{{ section.id }}::after  { bottom: 18px; right: 28px; }

  .feature-bar__item--{{ section.id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: {{ section.settings.item_inner_gap }}px;
    flex: {{ section.settings.item_flex }};
    min-width: {{ section.settings.item_min_width }}px;
    max-width: {{ section.settings.item_max_width }}px;
    text-align: {{ align }};
    padding: {{ section.settings.item_padding_vertical }}px {{ section.settings.item_padding_horizontal }}px;
    margin: {{ section.settings.item_margin_vertical }}px {{ section.settings.item_margin_horizontal }}px;
  }

  .feature-bar__icon-wrap--{{ section.id }} {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: {{ section.settings.icon_border_radius }}%;
    background-color: {{ icon_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    position: relative;
  }

  .feature-bar__icon-wrap--{{ section.id }} img,
  .feature-bar__icon-wrap--{{ section.id }} svg {
    width: {{ section.settings.icon_inner_size }}px;
    height: {{ section.settings.icon_inner_size }}px;
    min-width: {{ section.settings.icon_inner_size }}px;
    min-height: {{ section.settings.icon_inner_size }}px;
    max-width: none;
    max-height: none;
    object-fit: contain;
    color: {{ icon_color }};
    fill: {{ icon_color }};
    flex-shrink: 0;
  }

  .feature-bar__text-wrap--{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.text_inner_gap }}px;
  }

  .feature-bar__heading--{{ section.id }} {
    margin: 0;
    color: {{ heading_color }};
    font-family: {{ heading_ff }};
    font-size: {{ section.settings.heading_font_size }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}em;
    line-height: {{ section.settings.heading_line_height }};
  }

  .feature-bar__desc--{{ section.id }} {
    margin: 0;
    color: {{ text_color }};
    font-family: {{ text_ff }};
    font-size: {{ section.settings.text_font_size }}px;
    font-weight: {{ section.settings.text_font_weight }};
    letter-spacing: {{ section.settings.text_letter_spacing }}em;
    line-height: {{ section.settings.text_line_height }};
  }

  /* ── Mobile overrides ── */
  @media (max-width: {{ section.settings.mobile_breakpoint }}px) {
    .feature-bar--{{ section.id }} {
      flex-direction: {{ section.settings.mobile_flex_direction }};
      padding-top: {{ section.settings.mobile_padding_vertical }}px;
      padding-bottom: {{ section.settings.mobile_padding_vertical }}px;
      padding-left: {{ section.settings.mobile_padding_horizontal }}px;
      padding-right: {{ section.settings.mobile_padding_horizontal }}px;
      gap: {{ section.settings.mobile_gap }}px;
      justify-content: {{ section.settings.mobile_justify_content }};
    }

    .feature-bar__item--{{ section.id }} {
      flex-direction: {{ section.settings.mobile_item_direction }};
      min-width: {{ section.settings.mobile_item_min_width }}px;
      max-width: 100%;
      gap: {{ section.settings.mobile_item_inner_gap }}px;
      text-align: {{ section.settings.mobile_text_align }};
      padding: {{ section.settings.mobile_item_padding_vertical }}px {{ section.settings.mobile_item_padding_horizontal }}px;
    }

    .feature-bar__icon-wrap--{{ section.id }} {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
    }

    .feature-bar__icon-wrap--{{ section.id }} img,
    .feature-bar__icon-wrap--{{ section.id }} svg {
      width: {{ section.settings.mobile_icon_inner_size }}px;
      height: {{ section.settings.mobile_icon_inner_size }}px;
    }

    .feature-bar__heading--{{ section.id }} {
      font-size: {{ section.settings.mobile_heading_font_size }}px;
    }

    .feature-bar__desc--{{ section.id }} {
      font-size: {{ section.settings.mobile_text_font_size }}px;
    }
  }
</style>

<div class="feature-bar--{{ section.id }}">
  {% for block in section.blocks %}
    {%- if block.type == 'feature' -%}
      <div class="feature-bar__item--{{ section.id }}" {{ block.shopify_attributes }}>

        {%- if block.settings.icon_image != blank or block.settings.icon_svg != blank -%}
          <div class="feature-bar__icon-wrap--{{ section.id }}">
            {%- if block.settings.icon_image != blank -%}
              {{
                block.settings.icon_image
                | image_url: width: 120
                | image_tag: loading: 'lazy', alt: block.settings.heading
              }}
            {%- elsif block.settings.icon_svg != blank -%}
              {{ block.settings.icon_svg }}
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="feature-bar__text-wrap--{{ section.id }}">
          {%- if block.settings.heading != blank -%}
            <p class="feature-bar__heading--{{ section.id }}">{{ block.settings.heading }}</p>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="feature-bar__desc--{{ section.id }}">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>

      </div>
    {%- endif -%}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Feature Bar",
  "tag": "section",
  "class": "section-feature-bar",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "🎨 Layout & Section"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFF0F3"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max section width (px)",
      "min": 600,
      "max": 1600,
      "step": 20,
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding_vertical",
      "label": "Vertical padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Horizontal padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "select",
      "id": "justify_content",
      "label": "Horizontal alignment",
      "options": [
        { "value": "flex-start",    "label": "Left" },
        { "value": "center",        "label": "Center" },
        { "value": "flex-end",      "label": "Right" },
        { "value": "space-between", "label": "Space between" },
        { "value": "space-around",  "label": "Space around" },
        { "value": "space-evenly",  "label": "Space evenly" }
      ],
      "default": "space-evenly"
    },
    {
      "type": "select",
      "id": "align_items",
      "label": "Vertical alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center",     "label": "Center" },
        { "value": "flex-end",   "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
