      ],
      "default": "0 1 auto"
    },
    {
      "type": "range",
      "id": "item_min_width",
      "label": "Item min-width (px)",
      "min": 100,
      "max": 400,
      "step": 10,
      "default": 200
    },
    {
      "type": "range",
      "id": "item_max_width",
      "label": "Item max-width (px)",
      "min": 100,
      "max": 600,
      "step": 10,
      "default": 320
    },
    {
      "type": "range",
      "id": "item_inner_gap",
      "label": "Icon ↔ Text gap (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "item_padding_vertical",
      "label": "Item vertical padding (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "item_padding_horizontal",
      "label": "Item horizontal padding (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "item_margin_vertical",
      "label": "Item vertical margin (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "item_margin_horizontal",
      "label": "Item horizontal margin (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "🖼️ Icon"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background color",
      "default": "#FFE4EC"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon / SVG color",
      "default": "#E8476A"
    },
    {
      "type": "number",
      "id": "icon_size",
      "label": "Icon circle size (px)",
      "default": 64
    },
    {
      "type": "number",
      "id": "icon_inner_size",
      "label": "Icon image size inside circle (px)",
      "default": 36
    },
    {
      "type": "range",
      "id": "icon_border_radius",
      "label": "Icon circle border-radius (%)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 50
    },
    {
      "type": "header",
      "content": "✏️ Heading Typography"
    },
    {
      "type": "color",
      "id": "heading_color",
