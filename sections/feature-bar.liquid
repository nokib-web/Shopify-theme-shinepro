        { "value": "1.4", "label": "1.4" },
        { "value": "1.6", "label": "1.6" }
      ],
      "default": "1.2"
    },
    {
      "type": "select",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "options": [
        { "value": "-0.02", "label": "Tight (-0.02em)" },
        { "value": "0",     "label": "Normal (0)" },
        { "value": "0.02",  "label": "Wide (0.02em)" },
        { "value": "0.05",  "label": "Wider (0.05em)" },
        { "value": "0.1",   "label": "Widest (0.1em)" }
      ],
      "default": "0"
    },
    {
      "type": "header",
      "content": "📝 Body Text Typography"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#555555"
    },
    {
      "type": "text",
      "id": "text_font_family",
      "label": "Body font family (CSS value)",
      "info": "e.g. 'Lato', sans-serif — leave as 'inherit' to use theme font",
      "default": "inherit"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Body font size (px)",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "select",
      "id": "text_font_weight",
      "label": "Body font weight",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "text_line_height",
      "label": "Body line height",
      "options": [
        { "value": "1.2", "label": "1.2" },
        { "value": "1.4", "label": "1.4" },
        { "value": "1.5", "label": "1.5" },
        { "value": "1.6", "label": "1.6" },
        { "value": "1.8", "label": "1.8" }
      ],
      "default": "1.5"
    },
    {
      "type": "select",
      "id": "text_letter_spacing",
