{%- style -%}
  .timeline-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_vertical_mobile }}px;
    padding-bottom: {{ section.settings.padding_vertical_mobile }}px;
    padding-left: {{ section.settings.padding_horizontal_mobile }}px;
    padding-right: {{ section.settings.padding_horizontal_mobile }}px;
    background: linear-gradient(to right, {{ section.settings.bg_gradient_left }}, {{ section.settings.bg_gradient_right }});
  }

  @media screen and (min-width: 750px) {
    .timeline-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_vertical_desktop }}px;
      padding-bottom: {{ section.settings.padding_vertical_desktop }}px;
      padding-left: {{ section.settings.padding_horizontal_desktop }}px;
      padding-right: {{ section.settings.padding_horizontal_desktop }}px;
    }
  }

  .timeline-wrapper-{{ section.id }} {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    text-align: center;
    font-family: inherit;
  }

  /* Title Styling */
  .timeline-title-{{ section.id }} {
    margin: 0 auto;
    font-size: {{ section.settings.title_font_size_mobile }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: {{ section.settings.title_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @media screen and (min-width: 750px) {
    .timeline-title-{{ section.id }} {
      font-size: {{ section.settings.title_font_size_desktop }}px;
    }
  }

  /* Title Underline Divider */
  .timeline-title-border-{{ section.id }} {
    content: "";
    display: block;
    margin: 8px auto 20px auto;
    height: {{ section.settings.border_height }}px;
    width: {{ section.settings.border_width }}px;
    background-color: {{ section.settings.border_color }};
  }

  /* Section Description Styling */
  .timeline-desc-{{ section.id }} {
    margin: 0 auto 50px auto;
    max-width: {{ section.settings.desc_max_width }}px;
    font-size: {{ section.settings.desc_font_size }}px;
    font-weight: {{ section.settings.desc_font_weight }};
    color: {{ section.settings.desc_color }};
    line-height: 1.5;
  }

  /* Horizontal Timeline Layout */
  .timeline-grid-{{ section.id }} {
    display: flex;
    flex-direction: column;
    position: relative;
    gap: 40px;
  }

  @media screen and (min-width: 750px) {
    .timeline-grid-{{ section.id }} {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
    }

    /* Connecting horizontal timeline line */
    .timeline-grid-{{ section.id }}::before {
      content: "";
      position: absolute;
      top: calc({{ section.settings.icon_container_size }}px / 2);
      left: 10%;
      right: 10%;
      height: 2px;
      background-color: {{ section.settings.border_color }};
      opacity: 0.5;
      z-index: 1;
    }
  }

  /* Timeline Block Styling */
  .timeline-block-{{ section.id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* Icon Ring and Container - circle size is independent from icon size */
  .timeline-icon-wrap-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_container_size }}px;
    height: {{ section.settings.icon_container_size }}px;
    flex-shrink: 0;
    border: 2px solid {{ section.settings.border_color }};
    background-color: #ffffff;
    border-radius: 50%;
    margin-bottom: 15px;
    box-sizing: border-box;
    overflow: visible;
    position: relative;
    z-index: 2;
  }

  .timeline-icon-wrap-{{ section.id }} img,
  .timeline-icon-wrap-{{ section.id }} svg {
    width: {{ section.settings.icon_size_mobile }}px !important;
    height: {{ section.settings.icon_size_mobile }}px !important;
    min-width: {{ section.settings.icon_size_mobile }}px !important;
    min-height: {{ section.settings.icon_size_mobile }}px !important;
    flex-shrink: 0;
    object-fit: contain;
    display: block;
    position: relative;
    z-index: 3;
  }

  @media screen and (min-width: 750px) {
    .timeline-icon-wrap-{{ section.id }} img,
    .timeline-icon-wrap-{{ section.id }} svg {
      width: {{ section.settings.icon_size_desktop }}px !important;
      height: {{ section.settings.icon_size_desktop }}px !important;
      min-width: {{ section.settings.icon_size_desktop }}px !important;
      min-height: {{ section.settings.icon_size_desktop }}px !important;
    }
  }

  /* Block Content Typography */
  .block-year-{{ section.id }} {
    margin: 5px 0;
    font-size: {{ section.settings.block_year_font_size }}px;
    font-weight: {{ section.settings.block_year_font_weight }};
    color: {{ section.settings.block_year_color }};
  }

  .block-title-{{ section.id }} {
    margin: 5px 0 10px 0;
    font-size: {{ section.settings.block_title_font_size }}px;
    font-weight: {{ section.settings.block_title_font_weight }};
    color: {{ section.settings.block_title_color }};
  }

  .block-desc-{{ section.id }} {
    margin: 0 auto;
    max-width: {{ section.settings.block_desc_max_width }}px;
    font-size: {{ section.settings.block_desc_font_size }}px;
    font-weight: {{ section.settings.block_desc_font_weight }};
    color: {{ section.settings.block_desc_color }};
    line-height: 1.4;
  }
{%- endstyle -%}

<section class="timeline-section-{{ section.id }}">
  <div class="timeline-wrapper-{{ section.id }}">
    
    {%- if section.settings.title != blank -%}
      <h2 class="timeline-title-{{ section.id }}">{{ section.settings.title }}</h2>
      <div class="timeline-title-border-{{ section.id }}"></div>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="timeline-desc-{{ section.id }}">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    <div class="timeline-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="timeline-block-{{ section.id }}" {{ block.shopify_attributes }}>
          
          <div class="timeline-icon-wrap-{{ section.id }}">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 400 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag }}
            {%- endif -%}
          </div>

          {%- if block.settings.year != blank -%}
            <h4 class="block-year-{{ section.id }}">{{ block.settings.year }}</h4>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="block-title-{{ section.id }}">{{ block.settings.title }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="block-desc-{{ section.id }}">{{ block.settings.description }}</p>
          {%- endif -%}
          
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

