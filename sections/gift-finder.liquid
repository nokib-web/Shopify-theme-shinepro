<style>
  #gift-finder-{{ section.id }} {
    --gf-bg:              {{ section.settings.bg_color }};
    --gf-accent:          {{ section.settings.accent_color }};
    --gf-accent-text:     {{ section.settings.accent_text_color }};
    --gf-card-bg:         {{ section.settings.card_bg_color }};
    --gf-card-border:     {{ section.settings.card_border_color }};
    --gf-btn-bg:          {{ section.settings.btn_bg_color }};
    --gf-btn-text:        {{ section.settings.btn_text_color }};
    --gf-btn-active-bg:   {{ section.settings.btn_active_bg_color }};
    --gf-btn-active-text: {{ section.settings.btn_active_text_color }};
    --gf-heading-color:   {{ section.settings.heading_color }};
    --gf-highlight-color: {{ section.settings.highlight_color }};
    --gf-sub-color:       {{ section.settings.subheading_color }};
    --gf-label-color:     {{ section.settings.label_color }};
    --gf-body-color:      {{ section.settings.body_color }};
    --gf-link-color:      {{ section.settings.link_color }};
    --gf-result-bg:       {{ section.settings.result_bg_color }};
    --gf-result-border:   {{ section.settings.result_border_color }};

    --gf-heading-size:    {{ section.settings.heading_size }}px;
    --gf-sub-size:        {{ section.settings.subheading_size }}px;
    --gf-subtitle-size:   {{ section.settings.subtitle_size }}px;
    --gf-label-size:      {{ section.settings.label_size }}px;
    --gf-btn-size:        {{ section.settings.btn_font_size }}px;
    --gf-body-size:       {{ section.settings.body_font_size }}px;

    --gf-card-radius:     {{ section.settings.card_border_radius }}px;
    --gf-btn-radius:      {{ section.settings.btn_border_radius }}px;
    --gf-card-gap:        {{ section.settings.card_gap }}px;
    --gf-btn-gap:         {{ section.settings.btn_gap }}px;
    --gf-card-padding:    {{ section.settings.card_padding }}px;
    --gf-btn-pv:          {{ section.settings.btn_padding_v }}px;
    --gf-btn-ph:          {{ section.settings.btn_padding_h }}px;

    background-color: var(--gf-bg);
    {%- if section.settings.bg_image != blank -%}
    background-image: url({{ section.settings.bg_image | image_url: width: 1600 }});
    background-size: {{ section.settings.bg_image_size }};
    background-position: {{ section.settings.bg_image_position }};
    background-repeat: no-repeat;
    {%- endif -%}
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_right }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_left }}px;
    font-family: var(--font-body-family, inherit);
  }

  .gf-inner { max-width: {{ section.settings.max_width }}px; margin: 0 auto; }

  .gf-header {
    text-align: {{ section.settings.text_align }};
    margin-bottom: {{ section.settings.header_bottom_margin }}px;
  }
  .gf-heading {
    font-size: var(--gf-heading-size);
    font-weight: {{ section.settings.heading_weight }};
    color: var(--gf-heading-color);
    text-transform: {{ section.settings.heading_transform }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    line-height: 1.1; margin: 0 0 4px;
  }
  .gf-subheading {
    font-size: var(--gf-sub-size);
    font-weight: {{ section.settings.subheading_weight }};
    color: var(--gf-highlight-color);
    text-transform: {{ section.settings.subheading_transform }};
    letter-spacing: {{ section.settings.subheading_letter_spacing }}px;
    line-height: 1.1; margin: 0 0 12px;
  }
  .gf-subtitle { font-size: var(--gf-subtitle-size); color: var(--gf-sub-color); margin: 0; }

  .gf-cards-wrap {
    display: flex; flex-wrap: wrap;
    gap: var(--gf-card-gap);
    justify-content: {{ section.settings.cards_justify }};
  }
  .gf-card {
    flex: 1 1 {{ section.settings.card_min_width }}px;
    max-width: {{ section.settings.card_max_width }}px;
    background: var(--gf-card-bg);
    border: {{ section.settings.card_border_width }}px solid var(--gf-card-border);
    border-radius: var(--gf-card-radius);
    padding: var(--gf-card-padding);
    display: flex; flex-direction: column; gap: var(--gf-btn-gap);
  }
  .gf-card.gf-card-selected { border-color: var(--gf-accent); border-width: {{ section.settings.card_border_active_width }}px; }
  .gf-card-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 12px;
  }
  .gf-card-icon-img {
    width: {{ section.settings.card_icon_size }}px;
    height: {{ section.settings.card_icon_size }}px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }
  @media (max-width: 749px) {
    .gf-card-icon-img {
      width: {{ section.settings.mobile_card_icon_size }}px;
      height: {{ section.settings.mobile_card_icon_size }}px;
    }
  }
  .gf-card-label {
    font-size: var(--gf-label-size);
    font-weight: {{ section.settings.label_weight }};
    color: var(--gf-label-color);
    text-align: {{ section.settings.text_align }};
    text-transform: {{ section.settings.label_transform }};
    letter-spacing: {{ section.settings.label_letter_spacing }}px;
    margin-bottom: {{ section.settings.label_bottom_margin }}px;
  }
  .gf-btn {
    display: block; width: 100%;
    padding: var(--gf-btn-pv) var(--gf-btn-ph);
    background: var(--gf-btn-bg); color: var(--gf-btn-text);
    border: 1px solid var(--gf-accent); border-radius: var(--gf-btn-radius);
    font-size: var(--gf-btn-size); font-weight: {{ section.settings.btn_font_weight }};
    text-align: {{ section.settings.btn_text_align }};
    text-transform: {{ section.settings.btn_transform }};
    letter-spacing: {{ section.settings.btn_letter_spacing }}px;
    line-height: 1.3; cursor: pointer; transition: all 0.2s ease; font-family: inherit;
  }
  .gf-btn:hover:not(.gf-active) { background: var(--gf-accent); color: #FFFFFF !important; border-color: var(--gf-accent); }
  .gf-btn.gf-active { background: var(--gf-btn-active-bg) !important; color: var(--gf-btn-active-text) !important; border-color: var(--gf-btn-active-bg) !important; font-weight: 700; }

  /* Result */
  .gf-result { display: none; margin-top: {{ section.settings.result_top_margin }}px; justify-content: center; }
  .gf-result.gf-show { display: flex; animation: gfFadeIn 0.4s ease; }
  @keyframes gfFadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .gf-result-box {
    background: var(--gf-result-bg);
    border: 2px solid var(--gf-result-border);
    border-radius: var(--gf-card-radius);
    padding: var(--gf-card-padding);
    width: 100%; max-width: {{ section.settings.result_max_width }}px; box-sizing: border-box;
  }
  .gf-result-inner { display: flex; flex-wrap: nowrap; gap: 20px; align-items: flex-start; }
  .gf-result-img {
    width: {{ section.settings.result_img_width }}px;
    min-width: {{ section.settings.result_img_width }}px;
    flex-shrink: 0; border-radius: {{ section.settings.result_img_radius }}px; overflow: hidden;
  }
  .gf-result-img img { width: 100%; height: auto; display: block; object-fit: cover; }
  .gf-result-info { flex: 1 1 0; min-width: 0; }
  .gf-result-match-label { font-size: var(--gf-label-size); font-weight: 800; color: var(--gf-heading-color); text-transform: uppercase; letter-spacing: 1px; margin: 0 0 6px; }
  .gf-result-stars { color: var(--gf-accent); font-size: 14px; margin-bottom: 4px; display: flex; align-items: center; gap: 2px; flex-wrap: wrap; }
  .gf-result-title { font-size: {{ section.settings.result_title_size }}px; font-weight: 700; color: var(--gf-heading-color); margin: 0 0 4px; }
  .gf-result-price { font-size: {{ section.settings.result_price_size }}px; font-weight: 700; color: var(--gf-heading-color); margin: 0 0 12px; }
  .gf-result-cta {
    display: block; width: 100%; box-sizing: border-box;
    background: var(--gf-btn-active-bg); color: var(--gf-btn-active-text);
    padding: 14px 24px; border-radius: var(--gf-btn-radius);
    font-size: var(--gf-btn-size); font-weight: 700;
    text-align: center; text-transform: uppercase; letter-spacing: 0.5px;
    border: none; cursor: pointer; transition: opacity 0.2s; font-family: inherit;
  }
  .gf-result-cta:hover { opacity: 0.85; }
  .gf-result-cta:disabled { opacity: 0.6; cursor: not-allowed; }
  .gf-result-link { display: block; margin-top: 8px; font-size: 13px; color: var(--gf-link-color); text-decoration: underline; text-align: center; }

  .gf-footer { text-align: {{ section.settings.text_align }}; margin-top: {{ section.settings.footer_top_margin }}px; font-size: var(--gf-body-size); color: var(--gf-body-color); }
  .gf-footer a { color: var(--gf-link-color); text-decoration: underline; }

  @media (max-width: 749px) {
    #gift-finder-{{ section.id }} {
      --gf-heading-size:  {{ section.settings.mobile_heading_size }}px;
      --gf-sub-size:      {{ section.settings.mobile_subheading_size }}px;
      --gf-subtitle-size: {{ section.settings.mobile_subtitle_size }}px;
      --gf-label-size:    {{ section.settings.mobile_label_size }}px;
      --gf-btn-size:      {{ section.settings.mobile_btn_font_size }}px;
      --gf-body-size:     {{ section.settings.mobile_body_font_size }}px;
      --gf-card-gap:      {{ section.settings.mobile_card_gap }}px;
      --gf-btn-gap:       {{ section.settings.mobile_btn_gap }}px;
      --gf-card-padding:  {{ section.settings.mobile_card_padding }}px;
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_right }}px {{ section.settings.mobile_padding_bottom }}px {{ section.settings.mobile_padding_left }}px;
    }
    .gf-cards-wrap { justify-content: {{ section.settings.mobile_cards_justify }}; }
    .gf-card { flex: 1 1 100%; max-width: 100%; }
    .gf-header { text-align: {{ section.settings.mobile_text_align }}; }
    .gf-result-box { max-width: 100%; }
    .gf-result-inner { flex-wrap: wrap; }
    .gf-result-img { width: 100%; min-width: unset; }
  }
</style>

<section id="gift-finder-{{ section.id }}">
  <div class="gf-inner">

    {%- if section.settings.show_header -%}
    <div class="gf-header">
      <h2 class="gf-heading">{{ section.settings.heading }}</h2>
      <p class="gf-subheading">{{ section.settings.subheading }}</p>
      <p class="gf-subtitle">{{ section.settings.subtitle }}</p>
    </div>
    {%- endif -%}

    <div class="gf-cards-wrap">
      {%- for col in (1..3) -%}
        {%- assign label_key = 'label_' | append: col -%}
        {%- assign icon_key  = 'col' | append: col | append: '_icon' -%}
        <div class="gf-card" id="gf-card{{ col }}-{{ section.id }}">
          {%- if section.settings[icon_key] != blank -%}
          <div class="gf-card-icon">
            <img class="gf-card-icon-img"
                 src="{{ section.settings[icon_key] | image_url: width: 200 }}"
                 alt="{{ section.settings[label_key] | escape }}">
          </div>
          {%- endif -%}
          <div class="gf-card-label">{{ section.settings[label_key] }}</div>
          {%- for i in (1..4) -%}
            {%- assign opt_key = 'col' | append: col | append: '_opt' | append: i -%}
            {%- if section.settings[opt_key] != blank -%}
              <button type="button" class="gf-btn" data-group="col{{ col }}" data-value="{{ section.settings[opt_key] | downcase }}">
                {{ section.settings[opt_key] }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="gf-result" id="gf-result-{{ section.id }}">
      <div class="gf-result-box">
        <div class="gf-result-inner">
          <div class="gf-result-img" id="gf-result-img-{{ section.id }}">
            <img id="gf-result-img-tag-{{ section.id }}" src="" alt="">
          </div>
          <div class="gf-result-info">
            <p class="gf-result-match-label">{{ section.settings.result_label }}</p>
            <div class="gf-result-stars" id="gf-result-stars-{{ section.id }}"></div>
            <h3 class="gf-result-title" id="gf-result-title-{{ section.id }}"></h3>
            <p class="gf-result-price" id="gf-result-price-{{ section.id }}"></p>
            <button type="button" class="gf-result-cta" id="gf-result-cta-{{ section.id }}">ADD TO CART</button>
            <a class="gf-result-link" id="gf-result-link-{{ section.id }}" href="#">{{ section.settings.result_view_details_text }}</a>
          </div>
        </div>
      </div>
    </div>

    {%- if section.settings.show_footer -%}
    <div class="gf-footer">
      {{ section.settings.footer_text }}
      {%- if section.settings.footer_link != blank -%}
        <a href="{{ section.settings.footer_link }}">{{ section.settings.footer_link_text }}</a>
      {%- endif -%}
    </div>
    {%- endif -%}

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var sid    = '{{ section.id }}';
  var root   = document.getElementById('gift-finder-' + sid);
  if (!root) return;

  /* ── Product data (Liquid → JS) ─────────────────────────────── */
  var products = [
    {% for block in section.blocks %}{% if block.type == 'product_match' %}
    {%- assign bp  = block.settings.product -%}
    {%- assign bpv = bp.selected_or_first_available_variant -%}
    {
      col1:      {{ block.settings.match_col1 | downcase | json }},
      col2:      {{ block.settings.match_col2 | downcase | json }},
      col3:      {{ block.settings.match_col3 | downcase | json }},
      title:     {{ bp.title | json }},
      price:     {{ bpv.price | money | json }},
      image:     {{ bp.featured_image | img_url: '480x' | json }},
      stars:     {{ bp.metafields.reviews.rating.value | default: '' | json }},
      reviews:   {{ bp.metafields.reviews.rating_count.value | default: '' | json }},
      variantId: {{ bpv.id | json }},
      url:       {{ bp.url | json }}
    },
    {% endif %}{% endfor %}
  ];

  /* ── State ───────────────────────────────────────────────────── */
  var state = { col1: null, col2: null, col3: null };

  /* ── Selection handler ───────────────────────────────────────── */
  root.addEventListener('click', function (e) {
    var btn = e.target.closest('.gf-btn');
    if (!btn) return;

    var group = btn.dataset.group;
    state[group] = btn.dataset.value;

    btn.closest('.gf-card').querySelectorAll('.gf-btn').forEach(function (b) {
      b.classList.toggle('gf-active', b === btn);
    });

    root.querySelectorAll('.gf-card').forEach(function (c, i) {
      c.classList.toggle('gf-card-selected', state['col' + (i + 1)] !== null);
    });

    if (state.col1 && state.col2 && state.col3) renderResult();
    else document.getElementById('gf-result-' + sid).classList.remove('gf-show');
  });

  /* ── Render matched product ──────────────────────────────────── */
  function renderResult() {
    var match = products.find(function (p) {
      return (p.col1 === '' || p.col1 === state.col1) &&
             (p.col2 === '' || p.col2 === state.col2) &&
             (p.col3 === '' || p.col3 === state.col3);
    }) || products[0];
    if (!match) return;

    /* image */
    var imgWrap = document.getElementById('gf-result-img-' + sid);
    var imgTag  = document.getElementById('gf-result-img-tag-' + sid);
    if (match.image) {
      imgTag.src = match.image;
      imgTag.alt = match.title || '';
      imgWrap.style.display = '';
    } else {
      imgWrap.style.display = 'none';
    }

    /* text */
    document.getElementById('gf-result-title-' + sid).textContent = match.title || '';
    document.getElementById('gf-result-price-' + sid).textContent = match.price || '';

    /* stars — use metafield values if available, else hide */
    var starsEl = document.getElementById('gf-result-stars-' + sid);
    if (match.stars) {
      var n = parseFloat(match.stars), html = '';
      for (var s = 1; s <= 5; s++) html += s <= Math.round(n) ? '★' : '☆';
      if (match.reviews) html += '<span style="color:var(--gf-sub-color);font-size:12px;margin-left:6px;">' + match.stars + ' · ' + match.reviews + ' reviews</span>';
      starsEl.innerHTML = html;
      starsEl.style.display = '';
    } else {
      starsEl.style.display = 'none';
    }

    /* CTA */
    var cta = document.getElementById('gf-result-cta-' + sid);
    cta.dataset.variantId = match.variantId || '';
    cta.textContent = 'ADD TO CART' + (match.price ? ' — ' + match.price : '');
    cta.disabled = false;

    /* link */
    var link = document.getElementById('gf-result-link-' + sid);
    if (match.url && match.url !== 'null') {
      link.href = match.url;
      link.style.display = '';
    } else {
      link.style.display = 'none';
    }

    /* animate */
    var result = document.getElementById('gf-result-' + sid);
    result.classList.remove('gf-show');
    void result.offsetWidth;
    result.classList.add('gf-show');
  }

  /* ── Add to cart (AJAX, no page reload) ─────────────────────── */
  document.addEventListener('click', function (e) {
    var cta = e.target.closest('#gf-result-cta-' + sid);
    if (!cta) return;
    e.preventDefault();

    var variantId = cta.dataset.variantId;
    if (!variantId || variantId === 'null') return;

    var original = cta.textContent;
    cta.textContent = 'Adding…';
    cta.disabled = true;

    /* Find Shrine's cart drawer section ID from the DOM so we can
       use the Sections Rendering API to get fresh HTML in one call */
    var cartDrawerEl  = document.querySelector('[id^="shopify-section"][id*="cart-drawer"], [id^="shopify-section"][id*="mini-cart"]');
    var cartIconEl    = document.querySelector('[id^="shopify-section"][id*="cart-icon"], [id^="shopify-section"][id*="cart-count"]');
    var sectionIds    = [];
    if (cartDrawerEl) sectionIds.push(cartDrawerEl.id.replace('shopify-section-', ''));
    if (cartIconEl)   sectionIds.push(cartIconEl.id.replace('shopify-section-', ''));

    var body = { id: parseInt(variantId, 10), quantity: 1 };
    if (sectionIds.length) body.sections = sectionIds;

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body:    JSON.stringify(body)
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.status) {
        cta.textContent = original;
        cta.disabled = false;
        return;
      }
      cta.textContent = '✓ Added!';

      /* If Shopify returned rendered section HTML, inject it directly */
      if (data.sections) {
        Object.keys(data.sections).forEach(function (sectionId) {
          var html    = data.sections[sectionId];
          var wrapper = document.getElementById('shopify-section-' + sectionId);
          if (!wrapper) return;
          var tmp = document.createElement('div');
          tmp.innerHTML = html;
          var inner = tmp.querySelector('[id="shopify-section-' + sectionId + '"]') || tmp.firstElementChild;
          if (inner) wrapper.innerHTML = inner.innerHTML;
        });
      }

      /* Open Shrine's cart drawer — try the web component first, then
         fall back to clicking whichever toggle button is in the DOM */
      var drawerEl = document.querySelector('mini-cart, cart-drawer');
      if (drawerEl && typeof drawerEl.open === 'function') {
        drawerEl.open();
      } else {
        var toggle = document.querySelector('[data-open-mini-cart], [aria-controls*="cart"], .js-toggle-cart');
        if (toggle) toggle.click();
      }

      /* Always fire cart:refresh on documentElement as a safety net */
      document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));

      setTimeout(function () { cta.textContent = original; cta.disabled = false; }, 1800);
    })
    .catch(function () { cta.textContent = original; cta.disabled = false; });
  });
});
</script>

{% schema %}
{
  "name": "Gift Finder",
  "tag": "section",
  "class": "gift-finder-section-wrapper",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "checkbox", "id": "show_header", "label": "Show header", "default": true },
    { "type": "text",    "id": "heading",    "label": "Main heading",    "default": "FIND THE RIGHT GIFT" },
    { "type": "text",    "id": "subheading", "label": "Highlighted subheading", "default": "IN SECONDS" },
    { "type": "text",    "id": "subtitle",   "label": "Subtitle",        "default": "Tell us who it's for and we'll point you to the best box." },
    { "type": "range",   "id": "header_bottom_margin", "label": "Header bottom margin", "min": 0, "max": 80, "step": 2, "default": 32, "unit": "px" },

    { "type": "header", "content": "Column Labels" },
    { "type": "text", "id": "label_1", "label": "Column 1 label", "default": "1. WHO IS IT FOR?" },
    { "type": "text", "id": "label_2", "label": "Column 2 label", "default": "2. WHAT'S THE OCCASION?" },
    { "type": "text", "id": "label_3", "label": "Column 3 label", "default": "3. CHOOSE A BOX SIZE" },

    { "type": "header", "content": "Column Icons" },
    { "type": "image_picker", "id": "col1_icon", "label": "Column 1 icon" },
    { "type": "image_picker", "id": "col2_icon", "label": "Column 2 icon" },
    { "type": "image_picker", "id": "col3_icon", "label": "Column 3 icon" },
    { "type": "range", "id": "card_icon_size",        "label": "Icon size (desktop)", "min": 40, "max": 160, "step": 4, "default": 80, "unit": "px" },
    { "type": "range", "id": "mobile_card_icon_size", "label": "Icon size (mobile)",  "min": 40, "max": 120, "step": 4, "default": 64, "unit": "px" },

    { "type": "header", "content": "Column 1 Options" },
    { "type": "text", "id": "col1_opt1", "label": "Option 1", "default": "STUDENT" },
    { "type": "text", "id": "col1_opt2", "label": "Option 2", "default": "FRIEND" },
    { "type": "text", "id": "col1_opt3", "label": "Option 3", "default": "FAMILY" },
    { "type": "text", "id": "col1_opt4", "label": "Option 4", "default": "TEAM / OFFICE" },

    { "type": "header", "content": "Column 2 Options" },
    { "type": "text", "id": "col2_opt1", "label": "Option 1", "default": "BIRTHDAY" },
    { "type": "text", "id": "col2_opt2", "label": "Option 2", "default": "GET WELL" },
    { "type": "text", "id": "col2_opt3", "label": "Option 3", "default": "THANK YOU" },
    { "type": "text", "id": "col2_opt4", "label": "Option 4", "default": "JUST BECAUSE" },

    { "type": "header", "content": "Column 3 Options" },
    { "type": "text", "id": "col3_opt1", "label": "Option 1", "default": "SMALL" },
    { "type": "text", "id": "col3_opt2", "label": "Option 2", "default": "MEDIUM" },
    { "type": "text", "id": "col3_opt3", "label": "Option 3", "default": "LARGE" },
    { "type": "text", "id": "col3_opt4", "label": "Option 4 (leave blank to hide)" },

    { "type": "header", "content": "Result Box" },
    { "type": "text",  "id": "result_label",            "label": "Match label",           "default": "YOUR PERFECT MATCH!" },
