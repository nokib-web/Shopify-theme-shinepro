{% style %}
  .about-jolly-good-box {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      to right,
      {{ section.settings.bg_gradient_left }},
      {{ section.settings.bg_gradient_right }}
    );
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
  }

  .about-jolly-good-box__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .about-jolly-good-box__wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
    flex-wrap: wrap;
  }

  .about-jolly-good-box__content {
    flex: 1 1 520px;
  }

  .about-jolly-good-box__subtitle {
    margin: 0 0 15px;
    color: {{ section.settings.subtitle_color }};
    font-weight: {{ section.settings.subtitle_weight }};
    font-size: {{ section.settings.subtitle_size_mobile }}px;
    line-height: 1.3;
  }

  .about-jolly-good-box__title {
    margin: 0 0 25px;
    color: {{ section.settings.title_color }};
    font-weight: {{ section.settings.title_weight }};
    font-size: {{ section.settings.title_size_mobile }}px;
    line-height: 1.1;
  }

  .about-jolly-good-box__description {
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size_mobile }}px;
    font-weight: {{ section.settings.description_weight }};
    line-height: 1.7;
    max-width: {{ section.settings.description_max_width }}px;
  }

  .about-jolly-good-box__image {
    flex: 1 1 500px;
    text-align: center;
  }

  .about-jolly-good-box__image img {
    width: 100%;
    max-width: {{ section.settings.image_width_desktop }}px;
    display: block;
    margin-left: auto;
    border-radius: 20px;
  }

  @media screen and (min-width: 768px) {
    .about-jolly-good-box {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      padding-left: 40px;
      padding-right: 40px;
    }

    .about-jolly-good-box__title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }

    .about-jolly-good-box__subtitle {
      font-size: {{ section.settings.subtitle_size_desktop }}px;
    }

    .about-jolly-good-box__description {
      font-size: {{ section.settings.description_size_desktop }}px;
    }
  }

  @media screen and (max-width: 767px) {
    .about-jolly-good-box__wrapper {
      gap: 40px;
    }

    .about-jolly-good-box__image img {
      max-width: {{ section.settings.image_width_mobile }}px;
      margin: 0 auto;
    }
  }
{% endstyle %}

<section class="about-jolly-good-box">
  <div class="about-jolly-good-box__container">
    <div class="about-jolly-good-box__wrapper">

      <!-- Left Content -->
      <div class="about-jolly-good-box__content">

        {% if section.settings.subtitle != blank %}
          <div class="about-jolly-good-box__subtitle">
            {{ section.settings.subtitle }}
          </div>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="about-jolly-good-box__title">
            {{ section.settings.title }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="about-jolly-good-box__description">
            {{ section.settings.description }}
          </div>
        {% endif %}

      </div>

      <!-- Right Image -->
      <div class="about-jolly-good-box__image">
        {% if section.settings.hero_image != blank %}
          {{
            section.settings.hero_image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              alt: section.settings.title
          }}
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Hero Section",
  "settings": [

    {
      "type": "range",
      "id": "max_width",
      "label": "Container Max Width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "default": 1400
    },

    {
      "type": "color",
      "id": "bg_gradient_left",
      "label": "Background Gradient Left",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bg_gradient_right",
      "label": "Background Gradient Right",
      "default": "#ffdbe7"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Desktop Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Desktop Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 150,
      "step": 2,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "default": 50
    },

    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Spreading joy, one snack box at a time."
    },

    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "label": "Subtitle Font Size Desktop",
      "min": 12,
      "max": 60,
      "step": 1,
      "default": 28
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "label": "Subtitle Font Size Mobile",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 20
    },

    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#ff4f87"
    },

    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Subtitle Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },

    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "About Jolly Good Box"
    },

    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Title Font Size Desktop",
      "min": 24,
      "max": 100,
      "step": 2,
      "default": 64
    },

    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title Font Size Mobile",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 38
    },

    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#111111"
    },

    {
      "type": "select",
      "id": "title_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "800"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We're on a mission to make gifting (and snacking) simpler, happier, and more meaningful."
    },

    {
      "type": "range",
      "id": "description_size_desktop",
      "label": "Description Font Size Desktop",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 20
    },

    {
      "type": "range",
      "id": "description_size_mobile",
      "label": "Description Font Size Mobile",
      "min": 12,
      "max": 30,
      "step": 1,
      "default": 16
    },

    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#444444"
    },

    {
      "type": "select",
      "id": "description_weight",
      "label": "Description Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" }
      ],
      "default": "400"
    },

    {
      "type": "range",
      "id": "description_max_width",
      "label": "Description Max Width",
      "min": 300,
      "max": 900,
      "step": 10,
      "default": 620
    },

    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },

    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Image Width Desktop",
      "min": 300,
      "max": 900,
      "step": 10,
      "default": 700
    },

    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Image Width Mobile",
      "min": 200,
      "max": 500,
      "step": 10,
      "default": 320
    }

  ],

  "presets": [
    {
      "name": "About Hero Section"
    }
  ]
}
{% endschema %}