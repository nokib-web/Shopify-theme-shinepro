{%- style -%}
  :root {
    --jg-hero-bg-{{ section.id }}: {{ section.settings.background_color }};
    
    /* Spacing - Desktop */
    --jg-hero-pad-top-{{ section.id }}: {{ section.settings.pad_top }}px;
    --jg-hero-pad-bottom-{{ section.id }}: {{ section.settings.pad_bottom }}px;
    --jg-hero-mar-top-{{ section.id }}: {{ section.settings.mar_top }}px;
    --jg-hero-mar-bottom-{{ section.id }}: {{ section.settings.mar_bottom }}px;
    
    /* Spacing - Mobile */
    --jg-hero-pad-top-mob-{{ section.id }}: {{ section.settings.pad_top_mobile }}px;
    --jg-hero-pad-bottom-mob-{{ section.id }}: {{ section.settings.pad_bottom_mobile }}px;
    --jg-hero-mar-top-mob-{{ section.id }}: {{ section.settings.mar_top_mobile }}px;
    --jg-hero-mar-bottom-mob-{{ section.id }}: {{ section.settings.mar_bottom_mobile }}px;

    /* Fonts */
    --jg-hero-h-size-{{ section.id }}: {{ section.settings.heading_size }}px;
    --jg-hero-h-size-mob-{{ section.id }}: {{ section.settings.heading_size_mobile }}px;
    --jg-hero-p-size-{{ section.id }}: {{ section.settings.para_size }}px;
    --jg-hero-p-size-mob-{{ section.id }}: {{ section.settings.para_size_mobile }}px;
  }
  
  .jg-hero-{{ section.id }} {
    background-color: var(--jg-hero-bg-{{ section.id }});
    background-image: radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.6) 0%, rgba(253, 251, 247, 0.1) 100%);
    padding-top: var(--jg-hero-pad-top-{{ section.id }});
    padding-bottom: var(--jg-hero-pad-bottom-{{ section.id }});
    padding-left: 30px;
    padding-right: 30px;
    margin-top: var(--jg-hero-mar-top-{{ section.id }});
    margin-bottom: var(--jg-hero-mar-bottom-{{ section.id }});
    font-family: var(--jg-font-sans);
    overflow: hidden;
    position: relative;
  }
  .jg-hero__container {
    max-width: {% if section.settings.width_mode == 'boxed' %}1200px{% else %}100%{% endif %};
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .jg-hero__content {
    flex: 1;
    max-width: 520px;
  }
  .jg-hero__media {
    flex: 1.2;
    display: flex;
    justify-content: center;
    position: relative;
  }
  .jg-hero__image-wrapper {
    width: 100%;
    max-width: 600px;
    position: relative;
    border-radius: 12px;
    transition: transform 0.4s ease;
  }
  .jg-hero__image-wrapper:hover {
    transform: translateY(-5px);
  }
  .jg-hero__image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
  }
  
  /* Heading */
  .jg-hero__heading {
    font-family: var(--jg-font-serif);
    font-size: var(--jg-hero-h-size-{{ section.id }});
    font-weight: 700;
    color: var(--jg-color-blue);
    line-height: 1.15;
    margin: 0 0 20px 0;
    position: relative;
  }
  .jg-hero__heading span.gold-text {
    color: var(--jg-color-gold);
    position: relative;
  }
  .jg-hero__heart-icon {
    display: inline-block;
    width: 32px;
    height: 32px;
    fill: none;
    stroke: var(--jg-color-gold);
    stroke-width: 1.5;
    vertical-align: middle;
    margin-left: 10px;
    animation: pulse-heart 2s infinite ease-in-out;
  }
  
  @keyframes pulse-heart {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .jg-hero__text {
    font-size: var(--jg-hero-p-size-{{ section.id }});
    line-height: 1.6;
    color: #4a4a4a;
    margin: 0 0 35px 0;
  }
  
  /* Buttons */
  .jg-hero__buttons {
    display: flex;
    gap: 15px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .jg-hero__btn-solid {
    background-color: var(--jg-color-gold);
    color: #ffffff;
    font-weight: 600;
    font-size: 14px;
    padding: 14px 28px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease, transform 0.2s ease;
    box-shadow: 0 4px 10px rgba(197, 146, 53, 0.2);
  }
  .jg-hero__btn-solid:hover {
    background-color: var(--jg-color-gold-hover);
    transform: translateY(-2px);
  }
  .jg-hero__btn-outline {
    background-color: #ffffff;
    color: var(--jg-color-blue);
    font-weight: 600;
    font-size: 14px;
    padding: 14px 28px;
    border: 1px solid #d4cdbf;
    border-radius: 8px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .jg-hero__btn-outline:hover {
    background-color: var(--jg-color-bg-light);
    transform: translateY(-2px);
  }
  .jg-hero__btn-outline svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }
  
  /* Customer Reviews section */
  .jg-hero__reviews {
    display: flex;
    align-items: center;
    gap: 15px;
    flex-wrap: wrap;
  }
  .jg-hero__avatars {
    display: flex;
  }
  .jg-hero__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid var(--jg-color-bg-cream);
    object-fit: cover;
    margin-left: -8px;
  }
  .jg-hero__avatar:first-child {
    margin-left: 0;
  }
  .jg-hero__stars-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .jg-hero__stars {
    color: var(--jg-color-gold);
    font-size: 16px;
    letter-spacing: 2px;
    line-height: 1;
  }
  .jg-hero__review-text {
    font-size: 12px;
    font-weight: 500;
    color: #4a4a4a;
  }

  /* Decorative Leaf / Shadow Element */
  .jg-hero__decorative-shadow {
    position: absolute;
    right: 0;
    top: 0;
    width: 150px;
    height: 100%;
    background: radial-gradient(ellipse at 100% 0%, rgba(100, 125, 90, 0.08) 0%, rgba(255, 255, 255, 0) 70%);
    pointer-events: none;
  }
  
  @media (max-width: 991px) {
    .jg-hero-{{ section.id }} {
      padding-top: var(--jg-hero-pad-top-mob-{{ section.id }});
      padding-bottom: var(--jg-hero-pad-bottom-mob-{{ section.id }});
      margin-top: var(--jg-hero-mar-top-mob-{{ section.id }});
      margin-bottom: var(--jg-hero-mar-bottom-mob-{{ section.id }});
    }
    .jg-hero__container {
      flex-direction: column-reverse;
      text-align: center;
      gap: 30px;
    }
    .jg-hero__content {
      max-width: 100%;
    }
    .jg-hero__heading {
      font-size: var(--jg-hero-h-size-mob-{{ section.id }});
    }
    .jg-hero__text {
      font-size: var(--jg-hero-p-size-mob-{{ section.id }});
    }
    .jg-hero__buttons {
      justify-content: center;
    }
    .jg-hero__reviews {
      justify-content: center;
    }
  }

  {{ section.settings.custom_css }}
{%- endstyle -%}

<section 
  id="{{ section.settings.custom_id | default: section.id }}" 
  class="jg-hero-{{ section.id }} {{ section.settings.custom_class }}"
  style="{{ section.settings.custom_style }}"
>
  <div class="jg-hero__decorative-shadow"></div>
  <div class="jg-hero__container">
    
    <!-- Left Column: Content -->
    <div class="jg-hero__content">
      <h1 class="jg-hero__heading">
        {{ section.settings.heading }}
        <svg class="jg-hero__heart-icon" viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      </h1>
      
      <p class="jg-hero__text">
        {{ section.settings.text }}
      </p>
      
      <div class="jg-hero__buttons">
        {%- if section.settings.btn_1_label != blank -%}
          <a href="{{ section.settings.btn_1_link }}" class="jg-hero__btn-solid">{{ section.settings.btn_1_label }}</a>
        {%- endif -%}
        {%- if section.settings.btn_2_label != blank -%}
          <a href="{{ section.settings.btn_2_link }}" class="jg-hero__btn-outline">
            <svg viewBox="0 0 24 24">
              <path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm6 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1z"></path>
            </svg>
            {{ section.settings.btn_2_label }}
          </a>
        {%- endif -%}
      </div>
      
      <div class="jg-hero__reviews">
        <div class="jg-hero__avatars">
          <img class="jg-hero__avatar" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=faces" alt="Customer Avatar">
          <img class="jg-hero__avatar" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=faces" alt="Customer Avatar">
          <img class="jg-hero__avatar" src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop&crop=faces" alt="Customer Avatar">
          <img class="jg-hero__avatar" src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop&crop=faces" alt="Customer Avatar">
        </div>
        <div class="jg-hero__stars-wrapper">
          <div class="jg-hero__stars">★★★★★</div>
          <span class="jg-hero__review-text">{{ section.settings.rating_text }}</span>
        </div>
      </div>
    </div>
    
    <!-- Right Column: Media (Box Image) -->
    <div class="jg-hero__media">
      <div class="jg-hero__image-wrapper">
        {%- if section.settings.image != blank -%}
          <img class="jg-hero__image" src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image.alt | escape }}" width="600" height="auto" loading="eager">
        {%- else -%}
          <img class="jg-hero__image" src="{{ 'jolly-good-hero-box.png' | asset_url }}" alt="The Jolly Good Box - 45 Snack Count Box" width="600" height="auto" loading="eager">
        {%- endif -%}
      </div>
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Jolly Good Hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout Controls"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "Width Mode",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "boxed", "label": "Boxed (1200px)" }
      ],
      "default": "boxed"
    },
    {
      "type": "header",
      "content": "Content & Media"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#fdfbf7"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "A Gift They'll Actually Enjoy."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description Subtext",
      "default": "45+ popular snacks, beautifully packed and handmade in the USA. Perfect for birthdays, college students, employees, care packages, thank-you gifts, and more."
    },
    {
      "type": "text",
      "id": "btn_1_label",
      "label": "Button 1 Label",
      "default": "Shop Best Sellers"
    },
    {
      "type": "url",
      "id": "btn_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn_2_label",
      "label": "Button 2 Label",
      "default": "Take the Gift Finder Quiz"
    },
    {
      "type": "url",
      "id": "btn_2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Label",
      "default": "Rated 4.8/5 by thousands of happy customers"
    },
    {
      "type": "header",
      "content": "Typography Sliders"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 56
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "para_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body Size (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "para_size_mobile",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Body Size (Mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Spacing Sliders"
    },
    {
      "type": "range",
      "id": "pad_top",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "pad_bottom",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "mar_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "pad_bottom_mobile",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "mar_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "mar_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Advanced Settings"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS overrides"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom HTML Classes"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom HTML id"
    },
    {
      "type": "text",
      "id": "custom_style",
      "label": "Custom Inline Styles"
    }
  ],
  "presets": [
    {
      "name": "Jolly Good Hero Section"
    }
  ]
}
{% endschema %}
