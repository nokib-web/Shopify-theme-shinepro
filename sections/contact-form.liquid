{%- style -%}
  /* ── Section wrapper ── */
  .cf-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: {{ section.settings.padding_left_mobile }}px;
    padding-right: {{ section.settings.padding_right_mobile }}px;
    background-color: {{ section.settings.section_bg_color }};
    min-height: {{ section.settings.section_min_height_mobile }}px;
    width: 100%;
    box-sizing: border-box;
  }
  @media screen and (min-width: 750px) {
    .cf-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.padding_left }}px;
      padding-right: {{ section.settings.padding_right }}px;
      min-height: {{ section.settings.section_min_height }}px;
      max-width: {{ section.settings.section_max_width }}px;
      margin: 0 auto;
    }
  }

  /* ── Hero top area ── */
  .cf-hero-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 32px;
  }
  @media screen and (min-width: 750px) {
    .cf-hero-{{ section.id }} {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }
    .cf-hero-left-{{ section.id }} { flex: 1; }
    .cf-hero-right-{{ section.id }} {
      flex: 0 0 {{ section.settings.hero_img_width }}px;
      max-width: {{ section.settings.hero_img_width }}px;
    }
  }

  /* hero image */
  .cf-hero-img-{{ section.id }} img {
    width: 100%;
    height: {{ section.settings.hero_img_height_mobile }}px;
    object-fit: cover;
    border-radius: {{ section.settings.hero_img_border_radius }}px;
    display: block;
  }
  @media screen and (min-width: 750px) {
    .cf-hero-img-{{ section.id }} img {
      height: {{ section.settings.hero_img_height }}px;
    }
  }

  /* ── Hero texts ── */
  .cf-eyebrow-{{ section.id }} {
    font-size: {{ section.settings.eyebrow_size_mobile }}px;
    color: {{ section.settings.eyebrow_color }};
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  @media screen and (min-width: 750px) {
    .cf-eyebrow-{{ section.id }} { font-size: {{ section.settings.eyebrow_size }}px; }
  }
  .cf-hero-heading-{{ section.id }} {
    font-size: {{ section.settings.hero_heading_size_mobile }}px;
    color: {{ section.settings.hero_heading_color }};
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  @media screen and (min-width: 750px) {
    .cf-hero-heading-{{ section.id }} { font-size: {{ section.settings.hero_heading_size }}px; }
  }
  .cf-hero-subtext-{{ section.id }} {
    font-size: {{ section.settings.hero_subtext_size_mobile }}px;
    color: {{ section.settings.hero_subtext_color }};
    line-height: 1.6;
    margin: 0 0 28px;
  }
  @media screen and (min-width: 750px) {
    .cf-hero-subtext-{{ section.id }} { font-size: {{ section.settings.hero_subtext_size }}px; }
  }

  /* ── Trust badges ── */
  .cf-badges-{{ section.id }} {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .cf-badge-{{ section.id }} { text-align: center; }
  .cf-badge-icon-{{ section.id }} {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: {{ section.settings.badge_icon_bg }};
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 8px;
    color: {{ section.settings.badge_icon_color }};
    font-size: 20px;
  }
  .cf-badge-title-{{ section.id }} {
    font-size: {{ section.settings.badge_title_size }}px;
    font-weight: 700;
    color: {{ section.settings.badge_title_color }};
    margin: 0 0 2px;
  }
  .cf-badge-desc-{{ section.id }} {
    font-size: {{ section.settings.badge_desc_size }}px;
    color: {{ section.settings.badge_desc_color }};
    margin: 0;
    line-height: 1.4;
  }

  /* ── Main card row ── */
  .cf-card-row-{{ section.id }} {
    background: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    box-shadow: 0 2px 24px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    margin-bottom: 24px;
  }
  @media screen and (min-width: 750px) {
    .cf-card-row-{{ section.id }} { flex-direction: row; }
    .cf-form-col-{{ section.id }} {
      flex: 1;
      padding: 48px 40px;
      border-right: 1px solid rgba(0,0,0,0.07);
    }
    .cf-contacts-col-{{ section.id }} {
      flex: 0 0 340px;
      padding: 48px 40px;
    }
  }
  .cf-form-col-{{ section.id }}, .cf-contacts-col-{{ section.id }} {
    padding: 32px 24px;
  }

  /* "or" divider on mobile */
  .cf-or-divider-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #999;
    font-size: 14px;
    margin: 8px 0;
  }
  .cf-or-divider-{{ section.id }}::before,
  .cf-or-divider-{{ section.id }}::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(0,0,0,0.1);
  }
  @media screen and (min-width: 750px) {
    .cf-or-divider-{{ section.id }} { display: none; }
    .cf-or-vert-{{ section.id }} {
      display: flex;
      align-items: center;
      justify-content: center;
      writing-mode: horizontal-tb;
      font-size: 13px;
      color: #999;
      position: absolute;
      right: -18px;
      top: 50%;
      transform: translateY(-50%);
      background: {{ section.settings.card_bg_color }};
      padding: 6px 0;
      z-index: 2;
    }
  }

  /* ── Form section labels ── */
  .cf-form-eyebrow-{{ section.id }} {
    font-size: {{ section.settings.form_eyebrow_size }}px;
    font-weight: 700;
    color: {{ section.settings.form_eyebrow_color }};
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .cf-form-heading-{{ section.id }} {
    font-size: {{ section.settings.form_heading_size_mobile }}px;
    font-weight: 800;
    color: {{ section.settings.form_heading_color }};
    margin: 0 0 6px;
  }
  @media screen and (min-width: 750px) {
    .cf-form-heading-{{ section.id }} { font-size: {{ section.settings.form_heading_size }}px; }
  }
  .cf-form-subtext-{{ section.id }} {
    font-size: {{ section.settings.form_subtext_size }}px;
    color: {{ section.settings.form_subtext_color }};
    margin: 0 0 24px;
  }

  /* ── Form fields ── */
  .cf-field-row-{{ section.id }} {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
  }
  .cf-field-row-{{ section.id }} .cf-field-wrap { flex: 1; }
  .cf-field-wrap { margin-bottom: 12px; }
  .cf-input-{{ section.id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ section.settings.input_border_color }};
    border-radius: {{ section.settings.input_border_radius }}px;
    font-size: {{ section.settings.input_font_size }}px;
    color: {{ section.settings.input_text_color }};
    background: {{ section.settings.input_bg_color }};
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.2s;
  }
  .cf-input-{{ section.id }}:focus { border-color: {{ section.settings.input_focus_border_color }}; }
  .cf-input-{{ section.id }}::placeholder { color: {{ section.settings.input_placeholder_color }}; }
  textarea.cf-input-{{ section.id }} {
    resize: vertical;
    min-height: {{ section.settings.textarea_min_height }}px;
  }

  /* ── Submit button ── */
  .cf-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    background: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: 700;
    border: none;
    border-radius: {{ section.settings.btn_border_radius }}px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cf-btn-{{ section.id }}:hover { background: {{ section.settings.btn_hover_color }}; }
  {% if section.settings.btn_full_width %}
    .cf-btn-{{ section.id }} { width: 100%; justify-content: center; }
  {% endif %}

  .cf-privacy-note-{{ section.id }} {
    font-size: 12px;
    color: {{ section.settings.form_subtext_color }};
    margin-top: 10px;
  }

  /* ── Contact info column ── */
  .cf-contacts-eyebrow-{{ section.id }} {
    font-size: {{ section.settings.form_eyebrow_size }}px;
    font-weight: 700;
    color: {{ section.settings.form_eyebrow_color }};
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .cf-contact-item-{{ section.id }} {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 28px;
  }
  .cf-contact-icon-wrap-{{ section.id }} {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: {{ section.settings.contact_icon_bg }};
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    color: {{ section.settings.contact_icon_color }};
  }
  .cf-contact-item-title-{{ section.id }} {
    font-size: {{ section.settings.contact_title_size }}px;
    font-weight: 700;
    color: {{ section.settings.contact_title_color }};
    margin: 0 0 2px;
  }
  .cf-contact-item-val-{{ section.id }} {
    font-size: {{ section.settings.contact_val_size }}px;
    font-weight: 600;
    color: {{ section.settings.contact_val_color }};
    margin: 0 0 2px;
  }
  .cf-contact-item-note-{{ section.id }} {
    font-size: {{ section.settings.contact_note_size }}px;
    color: {{ section.settings.contact_note_color }};
    margin: 0;
  }

  /* ── Bulk orders banner ── */
  .cf-bulk-banner-{{ section.id }} {
    background: {{ section.settings.bulk_bg_color }};
    border: 1px solid {{ section.settings.bulk_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: 24px 28px;
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .cf-bulk-icon-{{ section.id }} {
    width: 52px; height: 52px;
    background: {{ section.settings.bulk_icon_bg }};
    border-radius: 50%;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    color: {{ section.settings.bulk_icon_color }};
  }
  .cf-bulk-text-{{ section.id }} { flex: 1; min-width: 160px; }
  .cf-bulk-title-{{ section.id }} {
    font-size: {{ section.settings.bulk_title_size }}px;
    font-weight: 800;
    color: {{ section.settings.bulk_title_color }};
    margin: 0 0 4px;
  }
  .cf-bulk-desc-{{ section.id }} {
    font-size: {{ section.settings.bulk_desc_size }}px;
    color: {{ section.settings.bulk_desc_color }};
    margin: 0;
  }
  .cf-bulk-btn-{{ section.id }} {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    border: 2px solid {{ section.settings.bulk_btn_border_color }};
    background: transparent;
    color: {{ section.settings.bulk_btn_text_color }};
    font-size: {{ section.settings.bulk_btn_font_size }}px;
    font-weight: 700;
    border-radius: {{ section.settings.btn_border_radius }}px;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: background 0.2s, color 0.2s;
  }
  .cf-bulk-btn-{{ section.id }}:hover {
    background: {{ section.settings.bulk_btn_hover_bg }};
    color: {{ section.settings.bulk_btn_hover_text }};
  }

  /* ── Best sellers ── */
  .cf-bestsellers-{{ section.id }} {
    text-align: center;
    margin-bottom: 40px;
  }
  .cf-bs-heading-{{ section.id }} {
    font-size: {{ section.settings.bs_heading_size }}px;
    font-weight: 800;
    color: {{ section.settings.bs_heading_color }};
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: flex; align-items: center; justify-content: center; gap: 12px;
    margin: 0 0 28px;
  }
  .cf-bs-heading-{{ section.id }}::before,
  .cf-bs-heading-{{ section.id }}::after {
    content: '';
    flex: 0 0 40px;
    height: 1px;
    background: {{ section.settings.bs_divider_color }};
  }
  .cf-bs-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  @media screen and (min-width: 750px) {
    .cf-bs-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.bs_columns }}, 1fr);
    }
  }
  .cf-bs-card-{{ section.id }} {
    text-align: left;
    text-decoration: none;
  }
  .cf-bs-img-wrap-{{ section.id }} {
    width: 100%;
    height: {{ section.settings.bs_img_height_mobile }}px;
    overflow: hidden;
    border-radius: {{ section.settings.bs_img_border_radius }}px;
    margin-bottom: 10px;
    background: #f5f5f5;
  }
  @media screen and (min-width: 750px) {
    .cf-bs-img-wrap-{{ section.id }} { height: {{ section.settings.bs_img_height }}px; }
  }
  .cf-bs-img-wrap-{{ section.id }} img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cf-bs-product-title-{{ section.id }} {
    font-size: {{ section.settings.bs_product_title_size }}px;
    font-weight: 700;
    color: {{ section.settings.bs_product_title_color }};
    margin: 0 0 2px;
    line-height: 1.3;
  }
  .cf-bs-product-subtitle-{{ section.id }} {
    font-size: {{ section.settings.bs_product_subtitle_size }}px;
    color: {{ section.settings.bs_product_subtitle_color }};
    margin: 0 0 4px;
  }
  .cf-bs-product-price-{{ section.id }} {
    font-size: {{ section.settings.bs_product_price_size }}px;
    font-weight: 700;
    color: {{ section.settings.bs_product_price_color }};
    margin: 0 0 4px;
  }
  .cf-bs-stars-{{ section.id }} { color: {{ section.settings.bs_stars_color }}; font-size: 13px; }

  /* ── Error / Success states ── */
  #ContactFormCf-{{ section.id }} .cf-errors-container,
  #ContactFormCf-{{ section.id }} .cf-field-error {
    --color-foreground: {{ section.settings.errors_text_color.red }}, {{ section.settings.errors_text_color.green }}, {{ section.settings.errors_text_color.blue }};
    color: rgb(var(--color-foreground));
  }
  #ContactFormCf-{{ section.id }} .cf-success-container {
    --color-foreground: {{ section.settings.success_text_color.red }}, {{ section.settings.success_text_color.green }}, {{ section.settings.success_text_color.blue }};
    color: rgb(var(--color-foreground));
  }

  .color-scheme-{{ section.id }}.color-custom {
    --color-background: {{ section.settings.custom_colors_background.red }}, {{ section.settings.custom_colors_background.green }}, {{ section.settings.custom_colors_background.blue }};
    --gradient-background: {% if section.settings.custom_gradient_background != blank %}{{ section.settings.custom_gradient_background }}{% else %}{{ section.settings.custom_colors_background }}{% endif %};
    {% if section.settings.custom_image_background != blank %}
      {% # theme-check-disable %}
      --gradient-background: url('{{ section.settings.custom_image_background | img_url: 'master' }}') center center / cover no-repeat;
      {% # theme-check-enable %}
    {% endif %}
  }
  {% if section.settings.custom_mobile_image_background != blank %}
    @media screen and (max-width: 749px) {
      .color-scheme-{{ section.id }}.color-custom {
        {% # theme-check-disable %}
        --gradient-background: url('{{ section.settings.custom_mobile_image_background | img_url: 'master' }}') center center / cover no-repeat;
        {% # theme-check-enable %}
      }
    }
  {% endif %}
{%- endstyle -%}

<div class="color-scheme-{{ section.id }} color-{{ section.settings.color_scheme }} gradient content-for-grouping animate-section animate--hidden {{ section.settings.visibility }}">
  {% if section.settings.display_id %}
    <copy-button class='section-id-btn button' data-content="#shopify-section-{{ section.id }}" data-success="false">
      <span class="copy-text">Click to copy section ID</span>
      <span class="copy-success">ID copied successfully!</span>
    </copy-button>
  {% endif %}

  <div class="cf-section-{{ section.id }}">

    {%- comment -%}── HERO AREA ──{%- endcomment -%}
    <div class="cf-hero-{{ section.id }}">
      <div class="cf-hero-left-{{ section.id }}">
        {%- if section.settings.eyebrow_text != blank -%}
          <p class="cf-eyebrow-{{ section.id }}">{{ section.settings.eyebrow_text }}</p>
        {%- endif -%}
        {%- if section.settings.hero_heading != blank -%}
          <h1 class="cf-hero-heading-{{ section.id }}">{{ section.settings.hero_heading }}</h1>
        {%- endif -%}
        {%- if section.settings.hero_subtext != blank -%}
          <p class="cf-hero-subtext-{{ section.id }}">{{ section.settings.hero_subtext }}</p>
        {%- endif -%}

        {%- comment -%}── TRUST BADGES ──{%- endcomment -%}
        <div class="cf-badges-{{ section.id }}">
          {% if section.settings.badge1_title != blank %}
            <div class="cf-badge-{{ section.id }}">
              <div class="cf-badge-icon-{{ section.id }}">
                <span>{{ section.settings.badge1_icon }}</span>
              </div>
              <p class="cf-badge-title-{{ section.id }}">{{ section.settings.badge1_title }}</p>
              <p class="cf-badge-desc-{{ section.id }}">{{ section.settings.badge1_desc }}</p>
            </div>
          {% endif %}
          {% if section.settings.badge2_title != blank %}
            <div class="cf-badge-{{ section.id }}">
              <div class="cf-badge-icon-{{ section.id }}">
                <span>{{ section.settings.badge2_icon }}</span>
              </div>
              <p class="cf-badge-title-{{ section.id }}">{{ section.settings.badge2_title }}</p>
              <p class="cf-badge-desc-{{ section.id }}">{{ section.settings.badge2_desc }}</p>
            </div>
          {% endif %}
          {% if section.settings.badge3_title != blank %}
            <div class="cf-badge-{{ section.id }}">
              <div class="cf-badge-icon-{{ section.id }}">
                <span>{{ section.settings.badge3_icon }}</span>
              </div>
              <p class="cf-badge-title-{{ section.id }}">{{ section.settings.badge3_title }}</p>
              <p class="cf-badge-desc-{{ section.id }}">{{ section.settings.badge3_desc }}</p>
            </div>
          {% endif %}
        </div>
      </div>

      {%- if section.settings.hero_image != blank -%}
        <div class="cf-hero-right-{{ section.id }}">
          <div class="cf-hero-img-{{ section.id }}">
            {{ section.settings.hero_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.hero_image.alt }}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%}── FORM + CONTACTS CARD ──{%- endcomment -%}
    <div class="cf-card-row-{{ section.id }}" id="ContactFormCf-{{ section.id }}">

      {%- comment -%}── LEFT: FORM ──{%- endcomment -%}
      <div class="cf-form-col-{{ section.id }}" style="position:relative;">
        {%- if section.settings.form_eyebrow != blank -%}
          <p class="cf-form-eyebrow-{{ section.id }}">{{ section.settings.form_eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.form_heading != blank -%}
          <h2 class="cf-form-heading-{{ section.id }}">{{ section.settings.form_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.form_subtext != blank -%}
          <p class="cf-form-subtext-{{ section.id }}">{{ section.settings.form_subtext }}</p>
        {%- endif -%}

        <contact-form class="display-block">
          {% form 'contact', id: 'ContactFormCf', class: 'isolate' %}
            {%- if form.posted_successfully? -%}
              <div class="cf-success-container" style="padding:16px;border-radius:8px;background:#F2FFED;border:1px solid #28C100;color:#28C100;margin-bottom:16px;">
                ✓ {{ 'templates.contact.form.post_success' | t }}
              </div>
            {%- elsif form.errors -%}
              <div class="cf-errors-container" style="padding:16px;border-radius:8px;background:#fff5f5;border:1px solid #FF0000;color:#FF0000;margin-bottom:16px;">
                ⚠ {{ 'templates.contact.form.error_heading' | t }}:
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </div>
            {%- endif -%}

            {% if section.blocks.size > 0 %}
              {%- for block in section.blocks -%}
                {% case block.type %}
                  {% when 'field_row' %}
                    {% if block.settings.input_1_enabled and block.settings.input_2_enabled %}
                      <div class="cf-field-row-{{ section.id }}">
                    {% endif %}

                    {%- if block.settings.input_1_enabled -%}
                      {% liquid
                        case block.settings.input_1_type
                          when 'name'
                            assign field_1_name = 'templates.contact.form.name' | t
                          when 'email'
                            assign field_1_name = 'templates.contact.form.email' | t
                          when 'phone'
                            assign field_1_name = 'templates.contact.form.phone' | t
                          else
                            assign field_1_name = block.settings.input_1_custom_name | escape
                        endcase
                        assign req1 = false
                        if block.settings.input_1_required or block.settings.input_1_type == 'email'
                          assign req1 = true
                        endif
                      %}
                      <div class="cf-field-wrap">
                        <input
                          class="cf-input-{{ section.id }}"
                          type="{% if block.settings.input_1_type == 'email' %}email{% elsif block.settings.input_1_type == 'phone' %}tel{% else %}text{% endif %}"
                          id="CfField-{{ block.id }}-1"
                          {% if block.settings.input_1_type == 'email' %}name="contact[email]"{% else %}name="contact[{{ field_1_name }}]"{% endif %}
                          {% if block.settings.input_1_type == 'email' %}autocomplete="email" autocapitalize="off" spellcheck="false"
                          {% elsif block.settings.input_1_type == 'phone' %}autocomplete="tel" pattern="[0-9\-]*"
                          {% elsif block.settings.input_1_type == 'name' %}autocomplete="name"{% endif %}
                          {% if req1 %}aria-required="true"{% endif %}
                          placeholder="{{ field_1_name }}"
                        >
                      </div>
                    {%- endif -%}

                    {%- if block.settings.input_2_enabled -%}
                      {% liquid
                        case block.settings.input_2_type
                          when 'name'
                            assign field_2_name = 'templates.contact.form.name' | t
                          when 'email'
                            assign field_2_name = 'templates.contact.form.email' | t
                          when 'phone'
                            assign field_2_name = 'templates.contact.form.phone' | t
                          else
                            assign field_2_name = block.settings.input_2_custom_name | escape
                        endcase
                        assign req2 = false
                        if block.settings.input_2_required or block.settings.input_2_type == 'email'
                          assign req2 = true
                        endif
                      %}
                      <div class="cf-field-wrap">
                        <input
                          class="cf-input-{{ section.id }}"
                          type="{% if block.settings.input_2_type == 'email' %}email{% elsif block.settings.input_2_type == 'phone' %}tel{% else %}text{% endif %}"
                          id="CfField-{{ block.id }}-2"
                          {% if block.settings.input_2_type == 'email' %}name="contact[email]"{% else %}name="contact[{{ field_2_name }}]"{% endif %}
                          {% if block.settings.input_2_type == 'email' %}autocomplete="email" autocapitalize="off" spellcheck="false"
                          {% elsif block.settings.input_2_type == 'phone' %}autocomplete="tel" pattern="[0-9\-]*"
                          {% elsif block.settings.input_2_type == 'name' %}autocomplete="name"{% endif %}
                          {% if req2 %}aria-required="true"{% endif %}
                          placeholder="{{ field_2_name }}"
                        >
                      </div>
                    {%- endif -%}

                    {% if block.settings.input_1_enabled and block.settings.input_2_enabled %}</div>{% endif %}

                  {% when 'textarea' %}
                    <div class="cf-field-wrap">
                      {% liquid
                        if block.settings.input_type == 'comment'
                          assign textarea_name = 'templates.contact.form.comment' | t
                        else
                          assign textarea_name = block.settings.input_custom_name | escape
                        endif
                      %}
                      <textarea
                        class="cf-input-{{ section.id }}"
                        id="CfTextarea-{{ block.id }}"
                        name="contact[{{ textarea_name }}]"
                        {% if block.settings.input_required %}aria-required="true"{% endif %}
                        placeholder="{{ textarea_name }}"
                        {% if block.settings.max_characters != blank and block.settings.max_characters > 0 %}maxlength="{{ block.settings.max_characters }}"{% endif %}
                      >{% if block.settings.input_type == 'comment' %}{{ form.body }}{% endif %}</textarea>
                    </div>
                {% endcase %}
              {%- endfor -%}
            {% else %}
              {%- comment -%}Default layout{%- endcomment -%}
              <div class="cf-field-row-{{ section.id }}">
                <div class="cf-field-wrap">
                  <input class="cf-input-{{ section.id }}" type="text" name="contact[{{ 'templates.contact.form.name' | t }}]" placeholder="{{ 'templates.contact.form.name' | t }}" autocomplete="name">
                </div>
                <div class="cf-field-wrap">
                  <input class="cf-input-{{ section.id }}" type="tel" name="contact[{{ 'templates.contact.form.phone' | t }}]" placeholder="{{ 'templates.contact.form.phone' | t }}" autocomplete="tel" pattern="[0-9\-]*">
                </div>
              </div>
              <div class="cf-field-wrap">
                <input class="cf-input-{{ section.id }}" type="email" name="contact[email]" placeholder="{{ 'templates.contact.form.email' | t }}" autocomplete="email" autocapitalize="off" spellcheck="false" aria-required="true">
              </div>
              <div class="cf-field-wrap">
                <textarea class="cf-input-{{ section.id }}" name="contact[{{ 'templates.contact.form.comment' | t }}]" placeholder="{{ 'templates.contact.form.comment' | t }}">{{ form.body }}</textarea>
              </div>
            {% endif %}

            <button type="submit" class="cf-btn-{{ section.id }}">
              {%- if section.settings.btn_icon != blank -%}
                <span>{{ section.settings.btn_icon }}</span>
              {%- endif -%}
              {{ section.settings.btn_label }}
            </button>

            {%- if section.settings.privacy_note != blank -%}
              <p class="cf-privacy-note-{{ section.id }}">🔒 {{ section.settings.privacy_note }}</p>
            {%- endif -%}
          {%- endform -%}
        </contact-form>

        <div class="cf-or-vert-{{ section.id }}"></div>
      </div>

      <div class="cf-or-divider-{{ section.id }}">or</div>

      {%- comment -%}── RIGHT: CONTACT INFO ──{%- endcomment -%}
      <div class="cf-contacts-col-{{ section.id }}">
        {%- if section.settings.contacts_eyebrow != blank -%}
          <p class="cf-contacts-eyebrow-{{ section.id }}">{{ section.settings.contacts_eyebrow }}</p>
        {%- endif -%}

        {% if section.settings.contact1_title != blank %}
          <div class="cf-contact-item-{{ section.id }}">
            <div class="cf-contact-icon-wrap-{{ section.id }}">
              <span>{{ section.settings.contact1_icon }}</span>
            </div>
            <div>
              <p class="cf-contact-item-title-{{ section.id }}">{{ section.settings.contact1_title }}</p>
              <p class="cf-contact-item-val-{{ section.id }}">{{ section.settings.contact1_value }}</p>
              <p class="cf-contact-item-note-{{ section.id }}">{{ section.settings.contact1_note }}</p>
            </div>
          </div>
        {% endif %}

        {% if section.settings.contact2_title != blank %}
          <div class="cf-contact-item-{{ section.id }}">
            <div class="cf-contact-icon-wrap-{{ section.id }}">
              <span>{{ section.settings.contact2_icon }}</span>
            </div>
            <div>
              <p class="cf-contact-item-title-{{ section.id }}">{{ section.settings.contact2_title }}</p>
              <p class="cf-contact-item-val-{{ section.id }}">{{ section.settings.contact2_value }}</p>
              <p class="cf-contact-item-note-{{ section.id }}">{{ section.settings.contact2_note }}</p>
            </div>
          </div>
        {% endif %}

        {% if section.settings.contact3_title != blank %}
          <div class="cf-contact-item-{{ section.id }}">
            <div class="cf-contact-icon-wrap-{{ section.id }}">
              <span>{{ section.settings.contact3_icon }}</span>
            </div>
            <div>
              <p class="cf-contact-item-title-{{ section.id }}">{{ section.settings.contact3_title }}</p>
              <p class="cf-contact-item-val-{{ section.id }}">{{ section.settings.contact3_value }}</p>
              <p class="cf-contact-item-note-{{ section.id }}">{{ section.settings.contact3_note }}</p>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {%- comment -%}── BULK ORDERS BANNER ──{%- endcomment -%}
    {% if section.settings.bulk_title != blank %}
      <div class="cf-bulk-banner-{{ section.id }}">
        <div class="cf-bulk-icon-{{ section.id }}">
          <span>{{ section.settings.bulk_icon }}</span>
        </div>
        <div class="cf-bulk-text-{{ section.id }}">
          <p class="cf-bulk-title-{{ section.id }}">{{ section.settings.bulk_title }}</p>
          <p class="cf-bulk-desc-{{ section.id }}">{{ section.settings.bulk_desc }}</p>
        </div>
        {% if section.settings.bulk_btn_label != blank %}
          <a href="{{ section.settings.bulk_btn_link }}" class="cf-bulk-btn-{{ section.id }}">
            {{ section.settings.bulk_btn_label }} →
          </a>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%}── BEST SELLERS COLLECTION ──{%- endcomment -%}
    {% if section.settings.bs_collection != blank %}
      <div class="cf-bestsellers-{{ section.id }}">
        {%- if section.settings.bs_heading != blank -%}
          <h2 class="cf-bs-heading-{{ section.id }}">{{ section.settings.bs_heading }}</h2>
        {%- endif -%}
        <div class="cf-bs-grid-{{ section.id }}">
          {% assign bs_collection = collections[section.settings.bs_collection] %}
          {% assign bs_limit = section.settings.bs_product_limit %}
          {% for product in bs_collection.products limit: bs_limit %}
            <a href="{{ product.url }}" class="cf-bs-card-{{ section.id }}">
              <div class="cf-bs-img-wrap-{{ section.id }}">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: product.title }}
                {% endif %}
              </div>
              <p class="cf-bs-product-title-{{ section.id }}">{{ product.title | upcase | truncate: 30 }}</p>
              {% if product.metafields.custom.subtitle %}
                <p class="cf-bs-product-subtitle-{{ section.id }}">{{ product.metafields.custom.subtitle }}</p>
              {% endif %}
              <p class="cf-bs-product-price-{{ section.id }}">{{ product.price | money }}</p>
              <div class="cf-bs-stars-{{ section.id }}">★★★★★ <span style="color:#999;font-size:11px;">({{ product.metafields.reviews.rating_count | default: 0 }} reviews)</span></div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header","footer"] },
  "settings": [
    {
      "type": "checkbox",
      "id": "display_id",
      "label": "Display section ID",
      "default": false
    },
    {
      "type": "select",
      "id": "visibility",
      "options": [
        { "value": "desktop-hidden", "label": "Mobile only" },
        { "value": "mobile-hidden", "label": "Desktop only" },
        { "value": "always-display", "label": "All devices" }
      ],
      "label": "Display on",
      "default": "always-display"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Background 1" },
        { "value": "background-2", "label": "Background 2" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "section_bg_color",
